{
  "name": "repodcast",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:migrate:deploy": "prisma migrate deploy",
    "db:push": "prisma db push",
    "db:seed": "tsx prisma/seed.ts",
    "db:studio": "prisma studio",
    "dev:inngest": "npx inngest-cli@latest dev",
    "test": "vitest run",
    "test:watch": "vitest",
    "ai:validate": "tsx scripts/validate-voice.ts",
    "r2:cors": "tsx scripts/configure-r2-cors.ts",
    "prepare": "husky"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "~0.106.0",
    "@aws-sdk/client-s3": "~3.1075.0",
    "@aws-sdk/s3-request-presigner": "~3.1075.0",
    "@clerk/nextjs": "~7.5.9",
    "@prisma/adapter-pg": "~7.8.0",
    "@prisma/client": "~7.8.0",
    "@react-email/components": "~1.0.12",
    "@react-email/render": "~2.0.9",
    "@sentry/nextjs": "~10.62.0",
    "inngest": "~4.11.0",
    "next": "16.2.9",
    "pg": "~8.22.0",
    "posthog-js": "~1.395.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "resend": "~6.16.0",
    "stripe": "~22.3.0",
    "svix": "~1.96.1",
    "zod": "~4.4.3"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/pg": "~8.20.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitest/coverage-v8": "~4.1.9",
    "eslint": "^9",
    "eslint-config-next": "16.2.9",
    "husky": "~9.1.7",
    "lint-staged": "~16.4.0",
    "prettier": "~3.9.1",
    "prettier-plugin-tailwindcss": "~0.8.0",
    "prisma": "~7.8.0",
    "tailwindcss": "^4",
    "tsx": "~4.22.4",
    "typescript": "^5",
    "vitest": "~4.1.9"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx,mjs,cjs}": [
      "prettier --write",
      "eslint --fix"
    ],
    "*.{json,md,yml,yaml,css}": [
      "prettier --write"
    ]
  }
}
