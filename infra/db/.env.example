# Copy to .env.prod and .env.staging on your laptop. push.ps1 uploads it as .env
# on the VPS. NEVER commit filled-in copies — root .gitignore excludes .env*.

# ---------------------------------------------------------------------------
# Postgres
# ---------------------------------------------------------------------------
# Database name and role the app connects with. Match Prisma expectations.
POSTGRES_DB=repodcast
POSTGRES_USER=repodcast

# Long random password. Generate with: openssl rand -base64 48
# Different per env. Also update DATABASE_URL / DIRECT_URL in Vercel.
POSTGRES_PASSWORD=

# ---------------------------------------------------------------------------
# Backup scheduling (all optional — sensible defaults in docker-compose.yml)
# ---------------------------------------------------------------------------
# Cron expression for pg_dump. Default: 03:00 UTC daily.
BACKUP_SCHEDULE=0 3 * * *
BACKUP_KEEP_DAYS=7
BACKUP_KEEP_WEEKS=4
BACKUP_KEEP_MONTHS=6

# ---------------------------------------------------------------------------
# Offsite backup (rclone -> R2 / B2 / S3)
# ---------------------------------------------------------------------------
# rclone remote spec: "<remote-name>:<bucket>[/prefix]"
# Different bucket per env, e.g. repodcast-db-backups-prod / -staging.
OFFSITE_REMOTE=r2:repodcast-db-backups-prod
# How often to push local dumps to the remote (seconds). Default 1h.
OFFSITE_INTERVAL_SECONDS=3600

# ---------------------------------------------------------------------------
# TLS cert lifecycle (runs on the VPS — see scripts/renew.sh)
# ---------------------------------------------------------------------------
# Public hostname for the DB endpoint (what Vercel connects to).
# Cert is issued for this domain via lego + Cloudflare DNS-01.
DB_DOMAIN=db.repodcastapp.com

# Cloudflare API token with Zone.Zone:Read + Zone.DNS:Edit on repodcastapp.com.
# dash.cloudflare.com -> My Profile -> API Tokens -> Create Custom Token.
CLOUDFLARE_DNS_API_TOKEN=

# Email used to register with Let's Encrypt. Optional; default in renew.sh.
LEGO_EMAIL=contact@repodcastapp.com

# ---------------------------------------------------------------------------
# Cloudflare Tunnel — admin access to Postgres from your laptop.
# Create a NEW tunnel per env (repodcast-db-prod, repodcast-db-staging) with a
# TCP Private Network route to tcp://postgres:5432. See README §Cloudflared.
# ---------------------------------------------------------------------------
CLOUDFLARE_TUNNEL_TOKEN=
