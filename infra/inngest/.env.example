# Copy to .env.prod on your laptop, fill in values, then push.ps1 uploads
# it to the VPS as .env. NEVER commit filled-in copies — .env* is gitignored.

# --- Cloudflare Tunnel ------------------------------------------------------
# One-time value per tunnel from Zero Trust → Networks → Tunnels → Create.
# One tunnel serves both hostnames (see README §3).
CLOUDFLARE_TUNNEL_TOKEN="eyJhIjoi...replace..."

# --- Inngest secrets --------------------------------------------------------
# Same values MUST also be set in Vercel prod env (INNGEST_EVENT_KEY /
# INNGEST_SIGNING_KEY). Signing key must be even-length hex.
# Generate both: openssl rand -hex 32
INNGEST_EVENT_KEY="replace-with-hex-64"
INNGEST_SIGNING_KEY="replace-with-hex-64"

# --- Backup cadence ---------------------------------------------------------
# Snapshot SQLite hourly, mirror to R2 hourly. Match — a faster offsite sync
# than the snapshot cadence is wasted egress.
BACKUP_INTERVAL_SECONDS="3600"
OFFSITE_INTERVAL_SECONDS="3600"

# Local snapshot retention (hours). Because backup_offsite uses `rclone sync`,
# R2 mirrors this set — bump to keep a longer offsite tail as well.
BACKUP_KEEP_HOURS="168"

# --- Offsite destination ----------------------------------------------------
# Remote name comes from rclone.conf ("[r2]"), then :<bucket>.
OFFSITE_REMOTE="r2:repodcast-inngest-backups-prod"
