# Copy to `.env.prod` and `.env.staging` on your laptop (never commit them).
# push-env.sh scp's these to /home/deploy/{prod,staging}/.env on the box.

# ---- Identity ----
WORKER_ENV=prod                       # or "staging"
IMAGE_TAG=local                       # bumped by CI later; "local" is fine for VPS-built images

# ---- Auth ----
# Shared secret between the Next.js app and this worker. Any long random string.
# Generate: openssl rand -hex 32
WORKER_SHARED_SECRET="5503e279efa426a1f8bfe55881d269ebf943b0539facec48e00bb6b029f9b70c"

# ---- Cloudflare Tunnel ----
# From the Zero Trust dashboard → Networks → Tunnels → your tunnel → token.
# Prod and staging use different tokens (different tunnels).
CLOUDFLARE_TUNNEL_TOKEN=

# ---- R2 (reuse existing bucket + credentials from the Next.js app) ----
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
# Public base URL for the bucket — the worker returns URLs shaped as
# `${R2_PUBLIC_BASE_URL}/${key}` so the app can render <video src=...>
# without needing to sign per-request. MUST point at the same bucket
# as R2_BUCKET (matches the app's NEXT_PUBLIC_R2_PUBLIC_BASE_URL).
R2_PUBLIC_BASE_URL=

# ---- Observability ----
# New Sentry project "repodcast-worker" — same account as the app.
SENTRY_DSN=

# ---- Later (weeks 3+) ----
# DEEPGRAM_API_KEY=                    # transcript refetch for clip renders
# ANTHROPIC_API_KEY=                   # if we call Claude from the worker directly
