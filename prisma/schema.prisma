// Repodcast — Prisma schema
//
// Conventions:
// - cuid() IDs (Prisma 5+ default style)
// - createdAt/updatedAt on every long-lived model
// - @@index on every foreign key; @@unique where multi-tenant scoping demands it
// - Cascade deletes for "owned" children; SetNull for historical references
//   we want to preserve (usage logs, voice samples, approver pointers)
// - Connection URLs live in `prisma.config.ts` (Prisma 7 requires this; the
//   schema datasource block no longer accepts `url`/`directUrl`).
// - DATABASE_URL is the pooled connection used at runtime (PgBouncer).
// - DIRECT_URL is the unpooled connection used by `prisma migrate` only.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ============================================================
// Enums
// ============================================================

enum Plan {
  STUDIO
  AGENCY
  NETWORK
}

enum MemberRole {
  OWNER
  ADMIN
  EDITOR
  REVIEWER
}

enum Platform {
  TWITTER
  LINKEDIN
  INSTAGRAM
  TIKTOK
  SHOW_NOTES
  BLOG
  NEWSLETTER
}

enum EpisodeStatus {
  DRAFT
  PROCESSING
  READY
  ARCHIVED
  FAILED
}

enum OutputStatus {
  GENERATING
  READY
  IN_REVIEW
  APPROVED
  SCHEDULED
  PUBLISHED
  FAILED
}

enum TranscriptSource {
  PASTE
  UPLOAD
  RSS
  YOUTUBE
}

enum InvoiceStatus {
  DRAFT
  OPEN
  PAID
  VOID
  UNCOLLECTIBLE
}

/// Phase 2.13 — billing cadence on a per-client basis. Drives the renewals
/// cron + the statement generator's default period window.
enum BillingCycle {
  MONTHLY
  QUARTERLY
  ANNUAL
  PROJECT
}

/// Phase 2.13 — lifecycle state of an agency's client relationship.
enum ClientStatus {
  ACTIVE
  PAUSED
  CHURNED
}

/// Phase 3.x — cadence of the Repodcast SaaS subscription the agency carries
/// with us. Distinct from `BillingCycle` above (which is the *agency's* per-
/// client billing cadence). Defaults `MONTHLY`; flips to `ANNUAL` when the
/// Stripe webhook sees a sub keyed to one of the annual Price IDs.
enum BillingCadence {
  MONTHLY
  ANNUAL
}

enum MemberTransitionKind {
  INVITED
  INVITE_ACCEPTED
  INVITE_REVOKED
  ROLE_CHANGED
  REMOVED
  OWNER_TRANSFERRED
}

enum InviteStatus {
  PENDING
  ACCEPTED
  REVOKED
  EXPIRED
}

/// Phase 2.10 — the wizard step the user last cleared. `DONE` means the user
/// has either finished or explicitly skipped past step 3. The /onboarding
/// gate redirects to /dashboard iff step is `DONE`, so bailing mid-flow
/// resumes the wizard exactly where it was left. Existing pre-2.10 rows
/// default to `DONE` so they're not yanked back into the wizard on next sign-in.
enum OnboardingStep {
  WORKSPACE
  TEAMMATES
  CLIENT
  DONE
}

// ============================================================
// Tenant & access
// ============================================================

model Agency {
  id                   String   @id @default(cuid())
  name                 String
  plan                 Plan     @default(STUDIO)
  clerkOrgId           String?  @unique
  stripeCustomerId     String?  @unique
  stripeSubscriptionId String?  @unique
  /// Phase 2.13.6 — opt-out flag for the renewals cron. Defaults on; the
  /// agency-settings page exposes a toggle.
  renewalRemindersEnabled Boolean @default(true)
  /// Preferred display + billing currency for Repodcast's own SaaS plans.
  /// 3-letter ISO-4217. Used as the default in `createCheckoutSessionAction`;
  /// the billing page exposes a picker. Free-form String (not enum) so we
  /// can add currencies without a migration — `lib/currencies.ts` is the
  /// UI-side allowlist.
  preferredCurrency    String   @default("USD")
  /// Phase 2.5 — white-label assets used by the client-facing surfaces
  /// (portal, branded exports). Logo is an R2 public URL (same scheme as
  /// `Client.artworkUrl`); accent color is a 7-char hex string. Both
  /// nullable; client-facing renders fall back to Repodcast defaults when
  /// unset.
  brandLogoUrl         String?
  brandAccentColor     String?
  /// Phase 2.10 — the wizard step the founding OWNER last cleared. Written
  /// to `TEAMMATES` by `createAgencyForUser` (step 1 finishes when the row
  /// is created) and advanced from the wizard via `setOnboardingStepAction`.
  /// The /onboarding layout redirects to /dashboard only when this is `DONE`.
  /// Default `DONE` so existing rows aren't dragged back into the wizard.
  onboardingStep       OnboardingStep @default(DONE)
  /// Phase 3.x — cadence of the active Stripe sub. Webhook writes this from
  /// the chosen Price ID (monthly Price → `MONTHLY`, annual Price → `ANNUAL`).
  /// Used by the /pricing + /onboarding/plan flow to round-trip the picker
  /// state, and by `/settings/billing` to label the current sub.
  billingCadence       BillingCadence @default(MONTHLY)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  members              Member[]
  clients              Client[]
  invoices             Invoice[]
  usageLogs            UsageLog[]
  outputTransitions    OutputTransition[]
  invites              MemberInvite[]
  memberTransitions    MemberTransition[]
  billingRemindersSent BillingReminderSent[]
  onboardingNudgesSent OnboardingNudgeSent[]
  usageSnapshots       AgencyUsageSnapshot[]
}

model Member {
  id          String     @id @default(cuid())
  agencyId    String
  /// Clerk user id (`user_…`). Globally unique per Clerk user but a user may
  /// belong to several agencies — uniqueness is enforced at (agencyId, clerkUserId).
  clerkUserId String
  role        MemberRole @default(EDITOR)
  email       String
  name        String?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  agency             Agency             @relation(fields: [agencyId], references: [id], onDelete: Cascade)
  approvedOutputs    GeneratedOutput[]  @relation("OutputApprover")
  authoredTransitions OutputTransition[] @relation("TransitionAuthor")
  authoredInvites    MemberInvite[]     @relation("InviteAuthor")
  /// MemberTransition rows where this member did the action (changed a role, removed someone, etc.).
  actorOfMemberTransitions  MemberTransition[] @relation("MemberTransitionActor")
  /// MemberTransition rows that targeted this member (e.g. their role changed, they were removed).
  targetOfMemberTransitions MemberTransition[] @relation("MemberTransitionTarget")
  /// Phase 2.13 — client statements this member generated.
  authoredStatements        ClientStatement[]  @relation("StatementAuthor")
  /// Phase 2.13 — client-portal links this member minted.
  authoredPortalLinks       ClientPortalLink[] @relation("PortalLinkAuthor")

  @@unique([agencyId, clerkUserId])
  @@index([agencyId])
  @@index([clerkUserId])
}

/// Homegrown invitation flow (Phase 1.0 follow-up). Replaces the Clerk
/// Organization invite path so we no longer depend on Clerk Orgs for
/// teammate access. Tokens are opaque cuids — they're sent verbatim in the
/// invite email and matched verbatim on the /invite/[token] accept page.
model MemberInvite {
  id                String       @id @default(cuid())
  agencyId          String
  email             String
  role              MemberRole   @default(EDITOR)
  /// Opaque token used in the invite link. Unique across all agencies.
  token             String       @unique @default(cuid())
  status            InviteStatus @default(PENDING)
  invitedByMemberId String?
  /// Hard expiry — accept-page treats invites past this as `EXPIRED`.
  expiresAt         DateTime
  acceptedAt        DateTime?
  /// Clerk user id of whoever accepted, for audit. Null until accept.
  acceptedByClerkUserId String?
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt

  agency          Agency  @relation(fields: [agencyId], references: [id], onDelete: Cascade)
  invitedByMember Member? @relation("InviteAuthor", fields: [invitedByMemberId], references: [id], onDelete: SetNull)
  transitions     MemberTransition[]

  @@index([agencyId, status])
  @@index([email])
  @@index([invitedByMemberId])
}

// ============================================================
// Clients (agency customers) + Shows (podcasts) + voice config
// ============================================================
//
// Hierarchy: Agency → Client → Show → Episode → GeneratedOutput.
// A Client is the agency's *customer* (a company or person). A Show is a
// podcast that the Client produces — a Client can have many Shows. Voice
// samples, instructions, artwork, and host name all live on the Show
// because each podcast has its own voice profile.

model Client {
  id           String   @id @default(cuid())
  agencyId     String
  /// Customer name (company or person who hires the agency).
  name         String
  description  String?
  contactName  String?
  contactEmail String?
  /// Customer-side logo. Per-show artwork lives on `Show.artworkUrl`.
  artworkUrl   String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  agency Agency @relation(fields: [agencyId], references: [id], onDelete: Cascade)
  shows  Show[]
  /// Phase 2.13 — at most one billing profile per client; nullable on the
  /// Client side because v1 doesn't require agencies to fill one in.
  billingProfile       ClientBillingProfile?
  statements           ClientStatement[]
  portalLinks          ClientPortalLink[]
  billingRemindersSent BillingReminderSent[]

  @@index([agencyId])
}

model Show {
  id                 String   @id @default(cuid())
  clientId           String
  /// Podcast name.
  name               String
  /// Primary host. The voice engine is tuned to this host's writing.
  host               String
  description        String?
  artworkUrl         String?
  rssUrl             String?
  /// AI-generated narrative of the show's voice. Refreshed when sample count
  /// crosses a strength threshold (Phase 2.1).
  voiceDescription   String?
  /// Global custom-instruction rules the prompt builder always injects.
  globalInstructions String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  client               Client                    @relation(fields: [clientId], references: [id], onDelete: Cascade)
  episodes             Episode[]
  voiceSamples         VoiceSample[]
  platformInstructions ShowPlatformInstruction[]

  @@index([clientId])
}

model ShowPlatformInstruction {
  id        String   @id @default(cuid())
  showId    String
  platform  Platform
  rule      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  show Show @relation(fields: [showId], references: [id], onDelete: Cascade)

  @@unique([showId, platform])
  @@index([showId])
}

// ============================================================
// Episodes + generated outputs
// ============================================================

model Episode {
  id          String           @id @default(cuid())
  showId      String
  title       String
  transcript  String
  source      TranscriptSource
  audioUrl    String?
  externalUrl String?
  status      EpisodeStatus    @default(DRAFT)
  /// Free-text reason populated when a pipeline non-retriable error trips
  /// (RSS import 404, transcribe 4xx, etc.). Pairs with `status = FAILED`
  /// so the episode page can render a "what went wrong" banner with a
  /// retry / pick-a-different-source affordance.
  failureReason String?
  recordedAt  DateTime?
  durationSec Int?
  /// Cached `KeyMoment[]` (server/ai/key-moments.ts) extracted from the
  /// transcript during the generate pipeline. Surfaced on the episode page
  /// as clip suggestions so the user doesn't have to re-call Claude or
  /// scrub the transcript by hand. Null until generate-episode has run.
  keyMoments  Json?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  show         Show              @relation(fields: [showId], references: [id], onDelete: Cascade)
  outputs      GeneratedOutput[]
  usageLogs    UsageLog[]
  voiceSamples VoiceSample[]

  @@index([showId])
  @@index([status])
}

model GeneratedOutput {
  id                 String       @id @default(cuid())
  episodeId          String
  platform           Platform
  content            String
  status             OutputStatus @default(GENERATING)
  /// 1-indexed version within an (episode, platform) slot. Regenerating
  /// creates a new row with version+1 and stamps `supersededAt` on the prior
  /// row, so we keep the full history without losing tenant scoping.
  version            Int          @default(1)
  quality            Int?
  /// Cumulative Levenshtein distance of every in-place content edit on this
  /// version. `0` = the user approved exactly what the model wrote.
  /// Drives the dashboard's hero "Posted with no edits" KPI and is a more
  /// honest signal than the prior `version == 1` proxy, which mis-classified
  /// edited-then-approved v1 rows as untouched.
  editDistance       Int          @default(0)
  /// Free-text instruction that triggered this version's generation.
  lastInstruction    String?
  approvedAt         DateTime?
  approvedByMemberId String?
  /// When a newer version replaced this row. `null` on the current version.
  supersededAt       DateTime?
  /// Self-pointer to the prior version (null on v1). Held by the new row.
  previousVersionId  String?
  createdAt          DateTime     @default(now())
  updatedAt          DateTime     @updatedAt

  episode          Episode            @relation(fields: [episodeId], references: [id], onDelete: Cascade)
  approvedByMember Member?            @relation("OutputApprover", fields: [approvedByMemberId], references: [id], onDelete: SetNull)
  previousVersion  GeneratedOutput?   @relation("OutputVersionHistory", fields: [previousVersionId], references: [id], onDelete: SetNull)
  nextVersions     GeneratedOutput[]  @relation("OutputVersionHistory")
  voiceSamples     VoiceSample[]
  transitions      OutputTransition[]

  @@index([episodeId])
  @@index([episodeId, platform, supersededAt])
  @@index([platform])
  @@index([status])
  @@index([approvedByMemberId])
  @@index([previousVersionId])
}

/// Append-only log of status changes on `GeneratedOutput`. Powers the
/// dashboard activity feed and any future audit view. `agencyId` is
/// denormalized so the most common query (latest N transitions for an
/// agency, time-ordered) is a single-table read.
model OutputTransition {
  id         String       @id @default(cuid())
  agencyId   String
  outputId   String
  /// Null on system-driven pipeline transitions (Inngest functions).
  byMemberId String?
  /// Null when the output is first created (e.g. GENERATING is the initial state).
  fromStatus OutputStatus?
  toStatus   OutputStatus
  /// Optional free-text note (rejection reason, regenerate instruction, etc.).
  note       String?
  createdAt  DateTime     @default(now())

  agency Agency          @relation(fields: [agencyId], references: [id], onDelete: Cascade)
  output GeneratedOutput @relation(fields: [outputId], references: [id], onDelete: Cascade)
  member Member?         @relation("TransitionAuthor", fields: [byMemberId], references: [id], onDelete: SetNull)

  @@index([agencyId, createdAt])
  @@index([outputId, createdAt])
  @@index([byMemberId])
}

/// Append-only audit trail for team / membership changes — mirrors
/// `OutputTransition` but scoped to people instead of generated outputs.
/// Powers the Team activity feed and any future per-member audit view.
/// `agencyId` is denormalized for the same reason as OutputTransition:
/// "latest N transitions for an agency, time-ordered" is a single-table read.
model MemberTransition {
  id             String               @id @default(cuid())
  agencyId       String
  kind           MemberTransitionKind
  /// The member who performed the action. Null for self-actions or system
  /// records (e.g. invite accepted by a brand-new user).
  byMemberId     String?
  /// The member subject of the change. Null for INVITED / INVITE_REVOKED
  /// (those point at an `inviteId` + `email` instead — the Member row
  /// doesn't exist yet at INVITED, and the invite holds the email).
  targetMemberId String?
  /// The invite affected (for INVITED / INVITE_ACCEPTED / INVITE_REVOKED).
  inviteId       String?
  /// Email associated with the invite — copied at record time so the feed
  /// still reads correctly after an invite is hard-deleted or expired.
  email          String?
  /// Role transition for ROLE_CHANGED / OWNER_TRANSFERRED.
  fromRole       MemberRole?
  toRole         MemberRole?
  /// Optional free-text note (rejection reason, escape hatch for future).
  note           String?
  createdAt      DateTime             @default(now())

  agency Agency        @relation(fields: [agencyId], references: [id], onDelete: Cascade)
  actor  Member?       @relation("MemberTransitionActor", fields: [byMemberId], references: [id], onDelete: SetNull)
  target Member?       @relation("MemberTransitionTarget", fields: [targetMemberId], references: [id], onDelete: SetNull)
  invite MemberInvite? @relation(fields: [inviteId], references: [id], onDelete: SetNull)

  @@index([agencyId, createdAt])
  @@index([targetMemberId])
  @@index([byMemberId])
  @@index([inviteId])
}

// ============================================================
// Voice training data
// ============================================================

model VoiceSample {
  id                String   @id @default(cuid())
  showId            String
  platform          Platform
  content           String
  /// The output that was approved, if this sample came from one.
  generatedOutputId String?
  /// The episode the approved output belonged to, for traceability.
  episodeId         String?
  createdAt         DateTime @default(now())

  show            Show             @relation(fields: [showId], references: [id], onDelete: Cascade)
  generatedOutput GeneratedOutput? @relation(fields: [generatedOutputId], references: [id], onDelete: SetNull)
  episode         Episode?         @relation(fields: [episodeId], references: [id], onDelete: SetNull)

  @@index([showId, platform])
  @@index([generatedOutputId])
  @@index([episodeId])
}

// ============================================================
// Usage + billing
// ============================================================

model UsageLog {
  id           String   @id @default(cuid())
  agencyId     String
  episodeId    String?
  /// Model identifier (e.g. "claude-sonnet-4-6"). Free-form to survive provider changes.
  model        String
  inputTokens  Int
  outputTokens Int
  /// Total cost in USD cents.
  costCents    Int
  createdAt    DateTime @default(now())

  agency  Agency   @relation(fields: [agencyId], references: [id], onDelete: Cascade)
  episode Episode? @relation(fields: [episodeId], references: [id], onDelete: SetNull)

  @@index([agencyId, createdAt])
  @@index([episodeId])
}

model Invoice {
  id               String        @id @default(cuid())
  agencyId         String
  stripeInvoiceId  String        @unique
  amountCents      Int
  currency         String        @default("usd")
  status           InvoiceStatus
  hostedInvoiceUrl String?
  pdfUrl           String?
  periodStart      DateTime
  periodEnd        DateTime
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  agency Agency @relation(fields: [agencyId], references: [id], onDelete: Cascade)

  @@index([agencyId, createdAt])
}

// ============================================================
// Phase 2.13 — Client management & billing support
// ============================================================
//
// SCOPE BOUNDARY: Repodcast never collects, holds, or processes payments
// between an agency and its clients. These tables exist so the agency can
// invoice in its own accounting tool — they store metadata + the
// generated proof-of-work, never card data or transferred funds.

/// 1:1 with `Client` — billing metadata the agency captures for its own
/// records. Surfaced under the "Deliverables & Billing" tab on the client
/// page and consumed by the statement generator + renewals cron.
///
/// `retainerCents` and `ratePerEpisodeCents` are mutually exclusive at the
/// application layer (the form is a radio); both nullable so a brand-new
/// client can exist without one set.
model ClientBillingProfile {
  id                    String       @id @default(cuid())
  clientId              String       @unique
  billingContactName    String?
  billingContactEmail   String?
  retainerCents         Int?
  ratePerEpisodeCents   Int?
  billingCycle          BillingCycle @default(MONTHLY)
  /// ISO-4217 currency code (e.g. "USD"). Free-form to keep migrations
  /// cheap if we add support for non-listed currencies.
  currency              String       @default("USD")
  contractStartDate     DateTime?
  contractRenewalDate   DateTime?
  status                ClientStatus @default(ACTIVE)
  /// External URL the agency lists for its own payment page (Stripe
  /// payment-link, custom checkout, etc.). Surfaced as the only money-shaped
  /// CTA in the client portal — Repodcast does **not** process the payment.
  paymentLinkUrl        String?
  internalNotes         String?
  createdAt             DateTime     @default(now())
  updatedAt             DateTime     @updatedAt

  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  /// Hot path: "list all clients in status X for this agency" — the
  /// renewals cron pivots on `contractRenewalDate` + `status` together.
  @@index([status])
  @@index([contractRenewalDate])
}

/// Persisted snapshot of a generated period statement. Rendered once, then
/// served from R2 thereafter (so the agency + their client get the exact
/// same PDF the agency signed off on, even if the underlying outputs were
/// later edited or removed).
model ClientStatement {
  id                  String   @id @default(cuid())
  clientId            String
  /// Inclusive lower bound of the reporting window.
  periodStart         DateTime
  /// Inclusive upper bound of the reporting window.
  periodEnd           DateTime
  /// Snapshot totals as of `generatedAt`. Each is the count or sum that
  /// fell inside [periodStart, periodEnd]; the PDF/CSV rendered from this
  /// row carries the same numbers forever.
  episodeCount        Int
  outputCount         Int
  approvedCount       Int
  /// 0–100. Stored as Int (percentage rounded) — the UI doesn't surface
  /// sub-percent precision and a decimal column would complicate the JSON
  /// payload the deliverables webhook ships.
  approvalRatePct     Int
  /// Cost-to-serve in USD cents — sum of `UsageLog.costCents` joined via
  /// Episode → Show → Client across the window.
  costCents           Int
  generatedAt         DateTime @default(now())
  generatedByMemberId String?
  /// R2 object key for the rendered PDF; null until the renderer finishes.
  pdfStorageKey       String?
  /// R2 object key for the CSV export; null until the export endpoint runs.
  csvStorageKey       String?
  /// Set when the deliverables webhook successfully delivered this row.
  webhookDeliveredAt  DateTime?
  /// Id returned by the agency's webhook handler (e.g. the QuickBooks /
  /// Xero invoice id). Surfaced in the UI as "Delivered to <tool>".
  webhookExternalRef  String?

  client            Client  @relation(fields: [clientId], references: [id], onDelete: Cascade)
  generatedByMember Member? @relation("StatementAuthor", fields: [generatedByMemberId], references: [id], onDelete: SetNull)

  @@index([clientId, periodStart(sort: Desc)])
  @@index([clientId, generatedAt(sort: Desc)])
  @@index([generatedByMemberId])
}

/// Tokenized read-only access to the client portal. Pattern mirrors the
/// homegrown `MemberInvite` flow — opaque cuid token sent to the client out
/// of band; the `/portal/[token]` route lookups go through `getByToken`
/// (public, no `TenantContext`).
model ClientPortalLink {
  id                 String    @id @default(cuid())
  clientId           String
  token              String    @unique @default(cuid())
  expiresAt          DateTime
  createdByMemberId  String?
  revokedAt          DateTime?
  lastAccessedAt     DateTime?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  client          Client                  @relation(fields: [clientId], references: [id], onDelete: Cascade)
  createdByMember Member?                 @relation("PortalLinkAuthor", fields: [createdByMemberId], references: [id], onDelete: SetNull)
  accessLogs      ClientPortalAccessLog[]

  @@index([clientId, expiresAt])
  @@index([createdByMemberId])
}

/// Append-only audit log of portal views. One row per `GET /portal/[token]`
/// that resolves to a live link. `ipHash` is sha-256 of the request IP so
/// we can spot bursts without storing raw IPs; `userAgent` is the bare
/// header string. Both nullable since a real client view in a hardened
/// browser may strip either.
model ClientPortalAccessLog {
  id            String   @id @default(cuid())
  portalLinkId  String
  viewedAt      DateTime @default(now())
  ipHash        String?
  userAgent     String?

  portalLink ClientPortalLink @relation(fields: [portalLinkId], references: [id], onDelete: Cascade)

  @@index([portalLinkId, viewedAt(sort: Desc)])
}

/// Dedupe ledger for the renewals cron (Phase 2.13.6). The cron fires at the
/// 30-day and 7-day pre-renewal markers; this table makes both fire-exactly-
/// once across daily runs. A row's presence means the email was sent —
/// missing row + window-open = next run sends.
model BillingReminderSent {
  id        String   @id @default(cuid())
  agencyId  String
  clientId  String
  /// The pre-renewal marker that fired: "30d" or "7d".
  marker    String
  sentAt    DateTime @default(now())

  agency Agency @relation(fields: [agencyId], references: [id], onDelete: Cascade)
  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade, map: "BillingReminderSent_client_fkey")

  @@unique([clientId, marker])
  @@index([agencyId, sentAt])
}

/// Phase 2.10 — dedupe ledger for the onboarding drop-off-recovery cron.
/// The cron fires "finish setup" at 24h and "your first client is waiting"
/// at 72h after `Agency.createdAt` whenever onboarding hasn't finished. A
/// row's presence means that marker has been sent; missing row + window
/// open = next run sends. Same claim-before-send pattern as
/// `BillingReminderSent`.
model OnboardingNudgeSent {
  id       String   @id @default(cuid())
  agencyId String
  /// The drop-off marker that fired: "24h" (finish setup) or "72h" (first client).
  marker   String
  sentAt   DateTime @default(now())

  agency Agency @relation(fields: [agencyId], references: [id], onDelete: Cascade)

  @@unique([agencyId, marker])
  @@index([sentAt])
}

/// Idempotency ledger for inbound webhooks. Each row marks one provider
/// event as "already processed". The webhook handler `create`s a row before
/// dispatching; a duplicate insert collapses on the unique constraint and
/// the handler short-circuits to 204 (already processed). On dispatch
/// failure we delete the row so the provider's retry re-processes.
///
/// `source` is the provider key — `stripe`, `clerk`, `resend` — so we can
/// dedupe webhooks from every provider through the same table without
/// worrying about cross-provider event-id collisions.
///
/// Rows accumulate forever; a daily prune of `processedAt < now - 90 days`
/// can land as a cron when we see the row count grow (Stripe events older
/// than ~30 days are never retried, so 90 days is a comfortable window).
model WebhookDelivery {
  id          String   @id @default(cuid())
  source      String
  eventId     String
  eventType   String
  processedAt DateTime @default(now())

  @@unique([source, eventId])
  @@index([source, processedAt])
}

// ============================================================
// Phase 3.6 — ROOT user & platform admin backend
// ============================================================
//
// These tables sit ABOVE the tenant graph. A SystemAdmin is a Repodcast
// employee with global access, not a `Member` of any agency. They authenticate
// through Clerk like any other user; the gate is "is there a SystemAdmin row
// for this clerkUserId?", resolved by `server/auth/system.ts`.
//
// SECURITY POSTURE
// - SystemAuditLog is append-only. Every ROOT mutation flows through
//   `withSystemAudit(...)`, which writes the audit row in the SAME prisma
//   $transaction as the mutation. No mutation should ever land without a
//   matching audit row.
// - Soft-delete via `deactivatedAt` so audit FKs survive forever.

/// Platform-employee role granted to a Clerk user via `SystemAdmin`. Distinct
/// from `MemberRole`, which scopes a person inside ONE agency.
///
/// - ROOT     — full mutate access across every tenant (suspend, delete,
///              force-cancel, hard-delete content). Should be 1-2 max in
///              normal operation.
/// - OPERATOR — same read as ROOT; can act on day-to-day support (extend a
///              sub, re-fire a stuck Inngest run, flag a refund). Cannot
///              hard-delete agencies or invoke schema-touching ops.
/// - SUPPORT  — read everything; can initiate read-only impersonation and
///              write to a small surface (resend welcome, regenerate a
///              portal token).
/// - ANALYST  — read everything; NO write access. For finance/BI sharing
///              without the footgun.
enum SystemAdminRole {
  ROOT
  OPERATOR
  SUPPORT
  ANALYST
}

/// One row per Repodcast employee with platform-admin access. Resolved off
/// `clerkUserId`. Same Clerk user may also have `Member` rows in agencies
/// (e.g. the founder also runs a test agency) — the two contexts are looked
/// up independently.
model SystemAdmin {
  id            String          @id @default(cuid())
  /// Clerk user id (`user_…`). Resolved from `auth().userId` in
  /// `getSystemAdminContext`. Unique because each Clerk user maps to at most
  /// one platform-admin identity.
  clerkUserId   String          @unique
  email         String
  name          String?
  role          SystemAdminRole @default(SUPPORT)
  /// When true (default), `/root/*` will redirect to MFA setup if the Clerk
  /// session has no second factor. Off only via direct DB edit; UI never
  /// exposes a toggle so a ROOT can't downgrade their own posture.
  mfaEnforced   Boolean         @default(true)
  /// Last time this admin loaded any `/root/*` page. Updated best-effort in
  /// `requireSystemAdminContext`. Surfaced on the system-admin list for
  /// "who's actually using their access" hygiene.
  lastActiveAt  DateTime?
  /// Soft-delete tombstone. Lookups filter `deactivatedAt: null` so audit
  /// foreign-key history survives.
  deactivatedAt DateTime?
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  authoredAuditEntries SystemAuditLog[] @relation("AuditAuthor")

  @@index([role])
  @@index([deactivatedAt])
}

/// Phase 3.6.16 + 3.6.18 step 4 — nightly rollup of per-agency usage.
///
/// One row per (agency, UTC calendar day). Powers the `/root` overview's
/// hot paths so we stop running `groupBy` on `UsageLog` / `GeneratedOutput`
/// on every dashboard render. The current period (today) still reads live;
/// snapshots cover everything that's closed.
///
/// `date` is anchored to **midnight UTC** for one canonical key per day —
/// the unique constraint enforces "no two snapshots for the same day-agency",
/// which makes the nightly cron safely idempotent (upsert keyed on
/// (agencyId, date) → re-runs update, never duplicate).
///
/// `plan` is snapshotted at write time so the 12-week stacked-bar chart can
/// segment by the plan the agency was ON during that week — a customer
/// upgrading mid-month won't retroactively re-tag their old activity.
///
/// `revenueCents` rolls up PAID invoices' `amountCents`. Mixed-currency rows
/// would normally need conversion, but every Stripe invoice we ingest is
/// already in the agency's `preferredCurrency` and we don't currently
/// aggregate across agencies in non-USD reporting — see PLAN §3.6.7 for the
/// multi-currency cohort note.
model AgencyUsageSnapshot {
  id           String   @id @default(cuid())
  agencyId     String
  /// 00:00 UTC of the day this snapshot represents.
  date         DateTime
  /// The agency's plan at snapshot time.
  plan         Plan
  /// New episodes created on this UTC day, scoped to the agency.
  episodes     Int      @default(0)
  /// New current-version outputs created on this UTC day (excludes superseded).
  outputs      Int      @default(0)
  /// Sum of `UsageLog.costCents` for this UTC day.
  costCents    Int      @default(0)
  /// Sum of PAID invoices' `amountCents` for this UTC day.
  revenueCents Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  agency Agency @relation(fields: [agencyId], references: [id], onDelete: Cascade)

  /// One snapshot per agency-day. Backs the cron's idempotent upsert.
  @@unique([agencyId, date])
  /// Hot path for date-range aggregates ("sum for the current month").
  @@index([date])
  /// Hot path for per-agency time series ("show me this agency's last 90d").
  @@index([agencyId, date(sort: Desc)])
}

/// Append-only audit log of every ROOT-side write. Inserted in the SAME
/// `prisma.$transaction` as the mutation it describes, via the
/// `withSystemAudit(...)` wrapper. If the mutation rolls back, the audit row
/// rolls back too — and vice versa. There is no "wrote but didn't log" path.
///
/// The action key is a free-form dotted string (e.g. `agency.suspend`,
/// `member.impersonate`, `subscription.force_cancel`) keyed off a const map
/// in `server/db/system/audit-actions.ts` so the TS layer enforces consistency
/// while the column stays migration-stable.
///
/// `before` / `after` snapshot the row(s) touched. Stored as Json so we can
/// capture arbitrarily-shaped pre/post images without inventing a column.
model SystemAuditLog {
  id                String   @id @default(cuid())
  bySystemAdminId   String
  /// Dotted action key. See `server/db/system/audit-actions.ts`.
  action            String
  targetAgencyId    String?
  targetMemberId    String?
  /// Free-form entity-type tag (e.g. "agency", "subscription", "member"). Pairs
  /// with `targetEntityId` so we can audit rows the schema doesn't have a
  /// dedicated FK column for.
  targetEntityType  String?
  targetEntityId    String?
  before            Json?
  after             Json?
  /// Free-text reason the operator typed in the confirm dialog. Required for
  /// destructive actions at the action layer.
  note              String?
  /// Source IP at the time of the action. Raw (not hashed) — this is internal
  /// audit, not user-facing telemetry. Stripped to first non-trusted-proxy hop
  /// at the action layer.
  ipAddress         String?
  userAgent         String?
  createdAt         DateTime @default(now())

  bySystemAdmin SystemAdmin @relation("AuditAuthor", fields: [bySystemAdminId], references: [id], onDelete: Restrict)

  @@index([bySystemAdminId, createdAt(sort: Desc)])
  @@index([targetAgencyId, createdAt(sort: Desc)])
  @@index([action, createdAt(sort: Desc)])
  @@index([createdAt(sort: Desc)])
}
