// Repodcast — Prisma schema
//
// Conventions:
// - cuid() IDs (Prisma 5+ default style)
// - createdAt/updatedAt on every long-lived model
// - @@index on every foreign key; @@unique where multi-tenant scoping demands it
// - Cascade deletes for "owned" children; SetNull for historical references
//   we want to preserve (usage logs, voice samples, approver pointers)
// - Connection URLs live in `prisma.config.ts` (Prisma 7 requires this; the
//   schema datasource block no longer accepts `url`/`directUrl`).
// - DATABASE_URL is the pooled connection used at runtime (PgBouncer).
// - DIRECT_URL is the unpooled connection used by `prisma migrate` only.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ============================================================
// Enums
// ============================================================

enum Plan {
  SOLO
  STUDIO
  AGENCY
  NETWORK
}

enum MemberRole {
  OWNER
  ADMIN
  EDITOR
  REVIEWER
}

enum Platform {
  TWITTER
  LINKEDIN
  INSTAGRAM
  TIKTOK
  SHOW_NOTES
  BLOG
  NEWSLETTER
}

enum EpisodeStatus {
  DRAFT
  PROCESSING
  READY
  ARCHIVED
  FAILED
}

/// Fine-grained pipeline sub-state. `status` is the coarse public state
/// (DRAFT/PROCESSING/READY/ARCHIVED/FAILED); `stage` is the actual thing
/// running right now — used to drive the SSE stream + the "we're doing X"
/// panels on the episode page. PROCESSING covers three distinct phases
/// (IMPORTING/TRANSCRIBING/GENERATING) that used to be indistinguishable.
enum EpisodePipelineStage {
  PENDING
  IMPORTING
  TRANSCRIBING
  GENERATING
  COMPLETED
  FAILED
}

enum OutputStatus {
  GENERATING
  READY
  IN_REVIEW
  AWAITING_CLIENT_APPROVAL
  APPROVED
  SCHEDULED
  PUBLISHED
  FAILED
}

/// Q1 — VideoClip lifecycle. The clip row is created up-front once Claude
/// picks the highlight, so the UI can render a card immediately with a
/// PENDING pill. The Inngest → render-worker call flips it to RENDERING,
/// then to READY or FAILED depending on the worker's response.
enum ClipRenderStatus {
  PENDING
  RENDERING
  READY
  FAILED
}

/// Per-client toggle for who signs off on generated outputs before they
/// can be scheduled. INTERNAL = the agency's own OWNER/ADMIN/REVIEWER
/// approves via the dashboard (existing behavior). CLIENT = after the
/// agency's internal review, the output is sent to the end client via
/// the portal, and the client's approval is what unlocks scheduling.
/// Once client-approved, the output is fully frozen — no owner override.
enum ValidationMode {
  INTERNAL
  CLIENT
}

/// Kinds of in-app notifications. Kept narrow — one enum value per
/// user-facing event so the UI can pick copy + icon without inspecting
/// the body. `outputId`/`episodeId` on the row point at the subject.
enum NotificationKind {
  REVIEW_REQUESTED
  CLIENT_APPROVED
  CLIENT_REVISION_REQUESTED
}

/// Phase 3.3 — where a scheduled output actually publishes. BUFFER = the
/// agency has connected their own Buffer account and we POST to Buffer's
/// API. MANUAL = we track the intent in Repodcast; the user posts elsewhere
/// (or Buffer doesn't support the platform — e.g. SHOW_NOTES / BLOG /
/// NEWSLETTER) and flips PUBLISHED themselves.
enum ExternalScheduler {
  BUFFER
  MANUAL
}

enum TranscriptSource {
  PASTE
  UPLOAD
  RSS
  YOUTUBE
}

enum InvoiceStatus {
  DRAFT
  OPEN
  PAID
  VOID
  UNCOLLECTIBLE
}

/// Phase 2.13 — billing cadence on a per-client basis. Drives the renewals
/// cron + the statement generator's default period window.
enum BillingCycle {
  MONTHLY
  QUARTERLY
  ANNUAL
  PROJECT
}

/// Phase 2.13 — lifecycle state of an agency's client relationship.
enum ClientStatus {
  ACTIVE
  PAUSED
  CHURNED
}

/// Phase 3.x — cadence of the Repodcast SaaS subscription the agency carries
/// with us. Distinct from `BillingCycle` above (which is the *agency's* per-
/// client billing cadence). Defaults `MONTHLY`; flips to `ANNUAL` when the
/// Stripe webhook sees a sub keyed to one of the annual Price IDs.
enum BillingCadence {
  MONTHLY
  ANNUAL
}

enum MemberTransitionKind {
  INVITED
  INVITE_ACCEPTED
  INVITE_REVOKED
  ROLE_CHANGED
  REMOVED
  OWNER_TRANSFERRED
}

enum InviteStatus {
  PENDING
  ACCEPTED
  REVOKED
  EXPIRED
}

/// Phase 3.9 — trial lifecycle for the $1-activation, card-required trial
/// (length is `TRIAL_DAYS` in `lib/plans.ts` — currently 7 days; activation
/// fee is `TRIAL_ACTIVATION_FEE_CENTS`, non-refundable).
///
/// - NONE       — agency has never been on trial (default for legacy agencies
///                that signed up before trials, and for future paid-first flows).
/// - ACTIVE     — inside the trial window. Stripe subscription exists in
///                `trialing` status; `Agency.trialEndsAt` is in the future.
/// - CONVERTED  — trial ended with a successful first invoice charge. Agency
///                is now a paying customer on their chosen plan.
/// - EXPIRED    — trial ended without a successful charge (payment_failed).
///                Agency was auto-downgraded to STUDIO via the same path as a
///                canceled subscription.
/// - CANCELED   — user canceled the trial before it ended. No charge occurred.
enum TrialStatus {
  NONE
  ACTIVE
  CONVERTED
  EXPIRED
  CANCELED
}

/// Kind of in-app suggestion the reporter picked. `OTHER` is the escape
/// hatch so we never force a reporter to lie about their category. The
/// enum is deliberately narrow — anything beyond this and we build a
/// discovery surface, not a triage queue.
enum SuggestionType {
  BUG
  FEATURE_REQUEST
  IMPROVEMENT
  QUESTION
  OTHER
}

/// Lifecycle state of a `Suggestion`. Terminal states (`SHIPPED`,
/// `WONTFIX`) stamp `resolvedAt`; everything else is open triage.
enum SuggestionStatus {
  NEW
  TRIAGED
  PLANNED
  IN_PROGRESS
  SHIPPED
  WONTFIX
}

// ============================================================
// Tenant & access
// ============================================================

model Agency {
  id                      String         @id @default(cuid())
  name                    String
  plan                    Plan           @default(STUDIO)
  clerkOrgId              String?        @unique
  stripeCustomerId        String?        @unique
  stripeSubscriptionId    String?        @unique
  /// Phase 2.13.6 — opt-out flag for the renewals cron. Defaults on; the
  /// agency-settings page exposes a toggle.
  renewalRemindersEnabled Boolean        @default(true)
  /// Preferred display + billing currency for Repodcast's own SaaS plans.
  /// 3-letter ISO-4217. Used as the default in `createCheckoutSessionAction`;
  /// the billing page exposes a picker. Free-form String (not enum) so we
  /// can add currencies without a migration — `lib/currencies.ts` is the
  /// UI-side allowlist.
  preferredCurrency       String         @default("USD")
  /// Phase 2.5 — white-label assets used by the client-facing surfaces
  /// (portal, branded exports). Logo is an R2 public URL (same scheme as
  /// `Client.artworkUrl`); accent color is a 7-char hex string. Both
  /// nullable; client-facing renders fall back to Repodcast defaults when
  /// unset.
  brandLogoUrl            String?
  brandAccentColor        String?
  /// Phase 3.x — cadence of the active Stripe sub. Webhook writes this from
  /// the chosen Price ID (monthly Price → `MONTHLY`, annual Price → `ANNUAL`).
  /// Used by the /pricing + /onboarding/plan flow to round-trip the picker
  /// state, and by `/settings/billing` to label the current sub.
  billingCadence          BillingCadence @default(MONTHLY)
  /// Phase 3.6.5 — ROOT-side suspension tombstone. Non-null = the agency is
  /// currently suspended; the tenant dashboard bounces to a "your account
  /// is suspended" screen. Read-only surfaces (data export) still resolve.
  /// Set by `suspendAgency`, cleared by `unsuspendAgency`, both audit-logged.
  suspendedAt             DateTime?
  /// Phase 3.6.5 — comp plan-override. When set, `getAgencyPlan()` returns
  /// this in place of `plan`. Used to grant an agency capacity above (or
  /// below) their paid tier without touching Stripe — comp accounts,
  /// partners, support escalations. Every grant / revoke lands an audit row
  /// with the operator's justification.
  ///
  /// Note: `planOverride` shapes CAPACITY only. Whether an agency has
  /// dashboard *access* without a Stripe sub is gated separately on
  /// `compAccessExpiresAt` below.
  planOverride            Plan?
  /// ROOT-granted free access. When non-null and in the future, the agency
  /// clears the "has active subscription" gate exactly as a Stripe sub would
  /// — the onboarding router routes them to /dashboard, the dashboard layout
  /// lets them through, and `assertActiveSubscription` accepts their writes.
  /// A past date is treated as "expired" (equivalent to null). Grant/revoke
  /// go through `withSystemAudit`.
  compAccessExpiresAt     DateTime?
  /// Phase 3.9 — trial lifecycle. `trialEndsAt` mirrors Stripe's
  /// `subscription.trial_end`; the webhook stamps it on `syncSubscription`.
  /// Null on agencies that never trialed (legacy + paid-first). `trialStatus`
  /// is the derived-but-persisted flag `banner`s and the ROOT filter read.
  /// Trial-eligibility check is `stripeCustomerId IS NULL` — one trial per
  /// Stripe customer, enforced in `checkoutFromOnboardingAction`.
  trialEndsAt             DateTime?
  trialStatus             TrialStatus    @default(NONE)
  /// Populated by `syncSubscription` when Stripe reports
  /// `cancel_at_period_end: true` — the timestamp equals
  /// `subscription.cancel_at` (falling back to the item-level
  /// `current_period_end`). Non-null means "subscription is scheduled
  /// to cancel"; `/settings/billing` surfaces the date + a Resume
  /// button that flips the Stripe flag back to false. Cleared on
  /// resume and on final subscription deletion.
  subscriptionCancelAt    DateTime?
  /// Populated by `syncSubscription` when Stripe reports an active
  /// discount on the sub (custom-priced deals for launch clients). Label
  /// is the Coupon's human `name`; endsAt is the Discount's `end` for
  /// `repeating` coupons (null for `forever` / `once`). Both are cleared
  /// when the sub no longer has an active discount. `/settings/billing`
  /// surfaces them as a banner so buyers see the negotiated rate + when
  /// the sticker price kicks in.
  activeDiscountLabel     String?
  activeDiscountEndsAt    DateTime?
  createdAt               DateTime       @default(now())
  updatedAt               DateTime       @updatedAt

  members              Member[]
  clients              Client[]
  invoices             Invoice[]
  usageLogs            UsageLog[]
  outputTransitions    OutputTransition[]
  invites              MemberInvite[]
  memberTransitions    MemberTransition[]
  billingRemindersSent BillingReminderSent[]
  onboardingNudgesSent OnboardingNudgeSent[]
  trialNudgesSent      TrialNudgeSent[]
  usageSnapshots       AgencyUsageSnapshot[]
  limitOverrides       AgencyLimitOverride[]
  integrations         AgencyIntegration[]
  notifications        Notification[]
  suggestions          Suggestion[]
  videoClips           VideoClip[]

  /// Same hot-path index as declared inline in the migration — mirrored here
  /// so `prisma migrate diff` stays clean on the next migration boundary.
  @@index([suspendedAt])
  /// Hot path for the "trial ending soon" cron scan and the ROOT filter.
  @@index([trialStatus, trialEndsAt])
}

model Member {
  id          String     @id @default(cuid())
  agencyId    String
  /// Clerk user id (`user_…`). Globally unique per Clerk user but a user may
  /// belong to several agencies — uniqueness is enforced at (agencyId, clerkUserId).
  clerkUserId String
  role        MemberRole @default(EDITOR)
  email       String
  name        String?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  agency                    Agency                 @relation(fields: [agencyId], references: [id], onDelete: Cascade)
  approvedOutputs           GeneratedOutput[]      @relation("OutputApprover")
  authoredTransitions       OutputTransition[]     @relation("TransitionAuthor")
  authoredInvites           MemberInvite[]         @relation("InviteAuthor")
  /// MemberTransition rows where this member did the action (changed a role, removed someone, etc.).
  actorOfMemberTransitions  MemberTransition[]     @relation("MemberTransitionActor")
  /// MemberTransition rows that targeted this member (e.g. their role changed, they were removed).
  targetOfMemberTransitions MemberTransition[]     @relation("MemberTransitionTarget")
  /// Phase 2.13 — client statements this member generated.
  authoredStatements        ClientStatement[]      @relation("StatementAuthor")
  /// Phase 2.13 — client-portal links this member minted.
  authoredPortalLinks       ClientPortalLink[]     @relation("PortalLinkAuthor")
  /// Phase 3.3 — outputs this member queued for publishing.
  scheduledOutputs          GeneratedOutput[]      @relation("OutputScheduler")
  /// Phase 3.3 — integrations this member connected (Buffer OAuth, etc.).
  connectedIntegrations     AgencyIntegration[]    @relation("IntegrationConnector")
  /// Phase 3.8 — portal feedback this member has triaged / acknowledged.
  readPortalFeedback        ClientPortalFeedback[] @relation("PortalFeedbackReader")
  /// Phase 3.8 — statements this member published to the client portal.
  sharedStatements          ClientStatement[]      @relation("StatementPortalPublisher")
  /// In-app notifications delivered to this member.
  notifications             Notification[]         @relation("NotificationRecipient")
  /// Notifications for which this member was the actor (e.g. the editor
  /// who requested review).
  actorOfNotifications      Notification[]         @relation("NotificationActor")
  /// In-app suggestions this member submitted.
  suggestions               Suggestion[]

  @@unique([agencyId, clerkUserId])
  @@index([agencyId])
  @@index([clerkUserId])
}

/// Homegrown invitation flow (Phase 1.0 follow-up). Replaces the Clerk
/// Organization invite path so we no longer depend on Clerk Orgs for
/// teammate access. Tokens are opaque cuids — they're sent verbatim in the
/// invite email and matched verbatim on the /invite/[token] accept page.
model MemberInvite {
  id                    String       @id @default(cuid())
  agencyId              String
  email                 String
  role                  MemberRole   @default(EDITOR)
  /// Opaque token used in the invite link. Unique across all agencies.
  token                 String       @unique @default(cuid())
  status                InviteStatus @default(PENDING)
  invitedByMemberId     String?
  /// Hard expiry — accept-page treats invites past this as `EXPIRED`.
  expiresAt             DateTime
  acceptedAt            DateTime?
  /// Clerk user id of whoever accepted, for audit. Null until accept.
  acceptedByClerkUserId String?
  createdAt             DateTime     @default(now())
  updatedAt             DateTime     @updatedAt

  agency          Agency             @relation(fields: [agencyId], references: [id], onDelete: Cascade)
  invitedByMember Member?            @relation("InviteAuthor", fields: [invitedByMemberId], references: [id], onDelete: SetNull)
  transitions     MemberTransition[]

  @@index([agencyId, status])
  @@index([email])
  @@index([invitedByMemberId])
}

// ============================================================
// Clients (agency customers) + Shows (podcasts) + voice config
// ============================================================
//
// Hierarchy: Agency → Client → Show → Episode → GeneratedOutput.
// A Client is the agency's *customer* (a company or person). A Show is a
// podcast that the Client produces — a Client can have many Shows. Voice
// samples, instructions, artwork, and host name all live on the Show
// because each podcast has its own voice profile.

model Client {
  id                 String         @id @default(cuid())
  agencyId           String
  /// Customer name (company or person who hires the agency).
  name               String
  description        String?
  contactName        String?
  contactEmail       String?
  /// Customer-side logo. Per-show artwork lives on `Show.artworkUrl`.
  artworkUrl         String?
  /// Who signs off on outputs before they can be scheduled. See enum
  /// docs — defaults to INTERNAL so existing clients keep the current
  /// dashboard-only approval flow.
  validationMode     ValidationMode @default(INTERNAL)
  /// Extra email addresses that receive workflow notifications (review
  /// requested, client approved / requested revision). The agency owner
  /// is always notified in addition to these; this list is a supplement,
  /// not a replacement.
  notificationEmails String[]       @default([])
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt

  agency               Agency                @relation(fields: [agencyId], references: [id], onDelete: Cascade)
  shows                Show[]
  /// Phase 2.13 — at most one billing profile per client; nullable on the
  /// Client side because v1 doesn't require agencies to fill one in.
  billingProfile       ClientBillingProfile?
  statements           ClientStatement[]
  portalLinks          ClientPortalLink[]
  billingRemindersSent BillingReminderSent[]

  @@index([agencyId])
}

model Show {
  id                 String   @id @default(cuid())
  clientId           String
  /// Podcast name.
  name               String
  /// Primary host. The voice engine is tuned to this host's writing.
  host               String
  description        String?
  artworkUrl         String?
  rssUrl             String?
  /// AI-generated narrative of the show's voice. Refreshed when sample count
  /// crosses a strength threshold (Phase 2.1) or drift is detected.
  voiceDescription   String?
  /// Sample count at the moment `voiceDescription` was last regenerated.
  /// Used by the drift-aware refresh gate to fire periodic re-writes past
  /// the fixed strength thresholds, and to throttle drift-triggered
  /// refreshes so a heavy-edit streak can't thrash Claude.
  voiceDescriptionSampleCount Int @default(0)
  /// Operator's verdict on the current `voiceDescription`. `null` = not
  /// rated yet (the default whenever the description gets re-written);
  /// `true` = "this reads like our voice"; `false` = "no, regenerate". A
  /// `false` verdict fires a refresh event and stays `false` until the
  /// refresh completes, at which point it resets to `null` for the fresh
  /// description to be rated on its own merit.
  voiceDescriptionApproved Boolean?
  /// Global custom-instruction rules the prompt builder always injects.
  globalInstructions String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  client               Client                    @relation(fields: [clientId], references: [id], onDelete: Cascade)
  episodes             Episode[]
  voiceSamples         VoiceSample[]
  platformInstructions ShowPlatformInstruction[]

  @@index([clientId])
}

model ShowPlatformInstruction {
  id        String   @id @default(cuid())
  showId    String
  platform  Platform
  rule      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  show Show @relation(fields: [showId], references: [id], onDelete: Cascade)

  @@unique([showId, platform])
  @@index([showId])
}

// ============================================================
// Episodes + generated outputs
// ============================================================

model Episode {
  id            String           @id @default(cuid())
  showId        String
  title         String
  transcript    String
  source        TranscriptSource
  audioUrl      String?
  externalUrl   String?
  /// Q1 — source video for clip generation. Populated during import for
  /// YOUTUBE episodes and UPLOAD-with-video. Null for audio-only sources
  /// (the clip pipeline falls back to an audiogram-style render).
  sourceVideoUrl String?
  status        EpisodeStatus    @default(DRAFT)
  /// Fine-grained pipeline sub-state. Drives the SSE stream + panel
  /// selection on `/episodes/[id]`. See `EpisodePipelineStage`.
  stage         EpisodePipelineStage @default(PENDING)
  /// Free-text reason populated when a pipeline non-retriable error trips
  /// (RSS import 404, transcribe 4xx, etc.). Pairs with `status = FAILED`
  /// so the episode page can render a "what went wrong" banner with a
  /// retry / pick-a-different-source affordance.
  failureReason String?
  recordedAt    DateTime?
  durationSec   Int?
  /// Cached `KeyMoment[]` (server/ai/key-moments.ts) extracted from the
  /// transcript during the generate pipeline. Surfaced on the episode page
  /// as clip suggestions so the user doesn't have to re-call Claude or
  /// scrub the transcript by hand. Null until generate-episode has run.
  keyMoments    Json?
  /// Q1 wk4 — Deepgram per-word timestamps kept alongside the flat
  /// transcript, so `server/ai/highlight-selection.ts` and the clip
  /// captions pipeline don't have to re-transcribe. Shape:
  /// `DeepgramWord[]` from server/transcription/deepgram.ts. Null on
  /// episodes transcribed before wk4 or on RSS/YouTube sources whose
  /// publisher-supplied transcript path skipped Deepgram entirely.
  transcriptWords Json?
  /// Q1 feature #4 — AI-generated hero artwork. All three variants share
  /// a single visual concept (Claude picks it once from the transcript);
  /// Workers AI renders each aspect ratio separately with flux-1-schnell.
  /// Null until generate-artwork has run. Overwritten when the user
  /// requests a regeneration.
  heroImageUrl     String?  // 16:9 — YouTube thumbnails, BLOG hero, NEWSLETTER hero
  squareCoverUrl   String?  // 1:1  — Apple Podcasts episode art, IG feed
  verticalCoverUrl String?  // 9:16 — Reels / TikTok / Shorts cover
  /// The visual concept Claude wrote before we called the image model.
  /// Kept so the UI can show "here's what we asked the model to draw"
  /// and so a "generate variants" flow can iterate on the same concept.
  artworkConcept   Json?
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt

  show          Show              @relation(fields: [showId], references: [id], onDelete: Cascade)
  outputs       GeneratedOutput[]
  usageLogs     UsageLog[]
  voiceSamples  VoiceSample[]
  notifications Notification[]
  videoClips    VideoClip[]

  @@index([showId])
  @@index([status])
}

model GeneratedOutput {
  id                  String             @id @default(cuid())
  episodeId           String
  platform            Platform
  content             String
  status              OutputStatus       @default(GENERATING)
  /// 1-indexed version within an (episode, platform) slot. Regenerating
  /// creates a new row with version+1 and stamps `supersededAt` on the prior
  /// row, so we keep the full history without losing tenant scoping.
  version             Int                @default(1)
  quality             Int?
  /// Cumulative Levenshtein distance of every in-place content edit on this
  /// version. `0` = the user approved exactly what the model wrote.
  /// Drives the dashboard's hero "Posted with no edits" KPI and is a more
  /// honest signal than the prior `version == 1` proxy, which mis-classified
  /// edited-then-approved v1 rows as untouched.
  editDistance        Int                @default(0)
  /// Free-text instruction that triggered this version's generation.
  lastInstruction     String?
  approvedAt          DateTime?
  approvedByMemberId  String?
  /// When the agency pushed this output to the client for portal-side
  /// approval (only used when `Client.validationMode = CLIENT`). While
  /// non-null and `clientApprovedAt` is null, the output sits in
  /// `AWAITING_CLIENT_APPROVAL` and is frozen for the agency.
  sentToClientAt      DateTime?
  /// Stamped when the end client hits "Approve" in the portal. Terminal
  /// — once set, the output cannot be edited or regenerated by anyone,
  /// even OWNER, and the row is treated as immutable content-wise.
  clientApprovedAt    DateTime?
  /// Email captured from the portal at the moment of client approval,
  /// for audit. Plain string (no FK) — portal users are not Members.
  clientApprovalEmail String?
  /// When a newer version replaced this row. `null` on the current version.
  supersededAt        DateTime?
  /// Self-pointer to the prior version (null on v1). Held by the new row.
  previousVersionId   String?
  /// Phase 3.6.10 — moderation flag columns. Populated when a tenant member
  /// (Phase 4 UI) or a ROOT operator (v1 manual entry) flags an output for
  /// review. `flaggedByMemberId` is a plain String — no FK — so a hard-deleted
  /// Member doesn't cascade-wipe the flag history.
  flagReason          String?
  flaggedByMemberId   String?
  flaggedAt           DateTime?
  /// Rule-adherence flags — human-readable strings describing which of
  /// the show's parseable voice rules this output broke. Populated at
  /// generation + regeneration time by `checkRuleAdherence` against the
  /// constraints extracted from `Show.globalInstructions` +
  /// `ShowPlatformInstruction.rule`. Empty = every parseable rule was
  /// followed (or the show has no parseable rules). The UI surfaces
  /// this as a small warning badge so the operator sees which rules
  /// were ignored without re-running the check client-side.
  ruleViolations      String[]           @default([])
  /// Phase 3.3 — scheduling surface. All four are populated together when
  /// APPROVED → SCHEDULED, cleared on unschedule, and `publishedAt` stamps
  /// on the terminal transition to PUBLISHED. `externalPostId` is Buffer's
  /// update id (or a Typefully draft id in a future provider). Null for
  /// MANUAL rows — the user is publishing elsewhere; we only track intent.
  scheduledFor        DateTime?
  scheduledByMemberId String?
  externalScheduler   ExternalScheduler?
  externalPostId      String?
  externalPostUrl     String?
  publishedAt         DateTime?
  /// Q1 feature #5 — audiogram (waveform video) attached to this output.
  /// `audiogramStatus` follows the same PENDING → RENDERING → READY | FAILED
  /// lifecycle as VideoClip; the four fields are populated together by the
  /// `generate-audiogram` Inngest fn and its render worker call. Null on
  /// outputs the user hasn't requested an audiogram for. `audiogramStartMs`
  /// and `audiogramEndMs` are the window we cut from the source audio
  /// (defaults to 0-60s until the trim editor lands).
  audiogramStatus     ClipRenderStatus?
  audiogramUrl        String?
  audiogramPosterUrl  String?
  audiogramError      String?
  audiogramStartMs    Int?
  audiogramEndMs      Int?
  audiogramAspect     String?            // "1:1" or "9:16"
  createdAt           DateTime           @default(now())
  updatedAt           DateTime           @updatedAt

  episode           Episode            @relation(fields: [episodeId], references: [id], onDelete: Cascade)
  approvedByMember  Member?            @relation("OutputApprover", fields: [approvedByMemberId], references: [id], onDelete: SetNull)
  scheduledByMember Member?            @relation("OutputScheduler", fields: [scheduledByMemberId], references: [id], onDelete: SetNull)
  previousVersion   GeneratedOutput?   @relation("OutputVersionHistory", fields: [previousVersionId], references: [id], onDelete: SetNull)
  nextVersions      GeneratedOutput[]  @relation("OutputVersionHistory")
  voiceSamples      VoiceSample[]
  transitions       OutputTransition[]
  notifications     Notification[]

  @@index([episodeId])
  @@index([episodeId, platform, supersededAt])
  @@index([platform])
  @@index([status])
  @@index([approvedByMemberId])
  @@index([scheduledByMemberId])
  @@index([previousVersionId])
  /// Hot path: "list all unresolved flagged outputs" on `/root/quality`.
  @@index([flaggedAt])
  /// Phase 3.3 — powers the /schedule calendar range query + the
  /// sync-scheduled-outputs cron scan.
  @@index([scheduledFor])
  @@index([status, scheduledFor])
}

/// Append-only log of status changes on `GeneratedOutput`. Powers the
/// dashboard activity feed and any future audit view. `agencyId` is
/// denormalized so the most common query (latest N transitions for an
/// agency, time-ordered) is a single-table read.
model OutputTransition {
  id         String        @id @default(cuid())
  agencyId   String
  outputId   String
  /// Null on system-driven pipeline transitions (Inngest functions).
  byMemberId String?
  /// Null when the output is first created (e.g. GENERATING is the initial state).
  fromStatus OutputStatus?
  toStatus   OutputStatus
  /// Optional free-text note (rejection reason, regenerate instruction, etc.).
  note       String?
  createdAt  DateTime      @default(now())

  agency Agency          @relation(fields: [agencyId], references: [id], onDelete: Cascade)
  output GeneratedOutput @relation(fields: [outputId], references: [id], onDelete: Cascade)
  member Member?         @relation("TransitionAuthor", fields: [byMemberId], references: [id], onDelete: SetNull)

  @@index([agencyId, createdAt])
  @@index([outputId, createdAt])
  @@index([byMemberId])
}

/// Append-only audit trail for team / membership changes — mirrors
/// `OutputTransition` but scoped to people instead of generated outputs.
/// Powers the Team activity feed and any future per-member audit view.
/// `agencyId` is denormalized for the same reason as OutputTransition:
/// "latest N transitions for an agency, time-ordered" is a single-table read.
model MemberTransition {
  id             String               @id @default(cuid())
  agencyId       String
  kind           MemberTransitionKind
  /// The member who performed the action. Null for self-actions or system
  /// records (e.g. invite accepted by a brand-new user).
  byMemberId     String?
  /// The member subject of the change. Null for INVITED / INVITE_REVOKED
  /// (those point at an `inviteId` + `email` instead — the Member row
  /// doesn't exist yet at INVITED, and the invite holds the email).
  targetMemberId String?
  /// The invite affected (for INVITED / INVITE_ACCEPTED / INVITE_REVOKED).
  inviteId       String?
  /// Email associated with the invite — copied at record time so the feed
  /// still reads correctly after an invite is hard-deleted or expired.
  email          String?
  /// Role transition for ROLE_CHANGED / OWNER_TRANSFERRED.
  fromRole       MemberRole?
  toRole         MemberRole?
  /// Optional free-text note (rejection reason, escape hatch for future).
  note           String?
  createdAt      DateTime             @default(now())

  agency Agency        @relation(fields: [agencyId], references: [id], onDelete: Cascade)
  actor  Member?       @relation("MemberTransitionActor", fields: [byMemberId], references: [id], onDelete: SetNull)
  target Member?       @relation("MemberTransitionTarget", fields: [targetMemberId], references: [id], onDelete: SetNull)
  invite MemberInvite? @relation(fields: [inviteId], references: [id], onDelete: SetNull)

  @@index([agencyId, createdAt])
  @@index([targetMemberId])
  @@index([byMemberId])
  @@index([inviteId])
}

/// In-app notifications for workflow events (review requested, client
/// approved, client requested revision). Recipient is always a Member
/// of the tenant agency; portal-side approvals fan out to configured
/// OWNER/ADMIN recipients. Email delivery is best-effort and independent
/// from the row — the row is the durable inbox source of truth.
model Notification {
  id            String           @id @default(cuid())
  agencyId      String
  memberId      String
  kind          NotificationKind
  /// Subject output, when the event is output-scoped. Nullable so future
  /// kinds (billing, integration health, etc.) can drop into the same
  /// table without a schema bump.
  outputId      String?
  episodeId     String?
  /// The Member who performed the action, when internal. Null for
  /// portal-side actions (the actor is the end client, not a Member).
  actorMemberId String?
  /// Free-text body — rendered as the notification's one-line summary.
  body          String
  readAt        DateTime?
  createdAt     DateTime         @default(now())

  agency  Agency           @relation(fields: [agencyId], references: [id], onDelete: Cascade)
  member  Member           @relation("NotificationRecipient", fields: [memberId], references: [id], onDelete: Cascade)
  actor   Member?          @relation("NotificationActor", fields: [actorMemberId], references: [id], onDelete: SetNull)
  output  GeneratedOutput? @relation(fields: [outputId], references: [id], onDelete: Cascade)
  episode Episode?         @relation(fields: [episodeId], references: [id], onDelete: Cascade)

  @@index([memberId, readAt, createdAt(sort: Desc)])
  @@index([agencyId, createdAt])
  @@index([outputId])
  @@index([episodeId])
  @@index([actorMemberId])
}

// ============================================================
// Voice training data
// ============================================================

model VoiceSample {
  id                String   @id @default(cuid())
  showId            String
  platform          Platform
  content           String
  /// The output that was approved, if this sample came from one.
  generatedOutputId String?
  /// The episode the approved output belonged to, for traceability.
  episodeId         String?
  createdAt         DateTime @default(now())

  show            Show             @relation(fields: [showId], references: [id], onDelete: Cascade)
  generatedOutput GeneratedOutput? @relation(fields: [generatedOutputId], references: [id], onDelete: SetNull)
  episode         Episode?         @relation(fields: [episodeId], references: [id], onDelete: SetNull)

  @@index([showId, platform])
  @@index([generatedOutputId])
  @@index([episodeId])
}

// ============================================================
// Video clips (Q1 — short-form clip generation)
// ============================================================

/// A single vertical clip cut from an episode. The row is created up-front
/// with `status = PENDING` after Claude picks the highlight span, so the
/// UI can render the placeholder card immediately. `renderedUrl` /
/// `posterUrl` fill in when the render worker (VPS + ffmpeg) uploads to
/// R2 and posts back the result.
///
/// `agencyId` is denormalized so tenant-isolation queries can filter
/// without joining through Episode → Show → Client → Agency.
model VideoClip {
  id             String           @id @default(cuid())
  episodeId      String
  agencyId       String
  /// Span within the source, aligned to Deepgram word timestamps.
  startMs        Int
  endMs          Int
  /// Claude's ranking (0–1) — hook strength × standalone comprehension ×
  /// emotional beat. Used to sort candidates and to A/B against actual
  /// post-publish engagement once analytics loopback lands (Q2 #2).
  score          Float
  /// One-sentence pitch from Claude explaining *why* this moment is a clip.
  /// Rendered under the poster in the UI so reviewers can skim without
  /// scrubbing.
  hookLine       String
  /// The source video the worker downloads/reads. Null → audiogram-style
  /// render from the episode's audio (audio-only podcasts, upload-source
  /// with no video track).
  sourceVideoUrl String?
  /// R2 URL of the rendered MP4. Null while status < READY.
  renderedUrl    String?
  /// R2 URL of the poster frame (first frame after burn-in). Same lifecycle.
  posterUrl      String?
  /// R2 URL of the SRT actually burnt in — kept so the trim editor can
  /// re-render without recomputing captions.
  captionsUrl    String?
  status         ClipRenderStatus @default(PENDING)
  /// Populated when status = FAILED. Short human-readable reason surfaced
  /// on the clip card, plus full stack in Sentry.
  renderError    String?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  episode Episode @relation(fields: [episodeId], references: [id], onDelete: Cascade)
  agency  Agency  @relation(fields: [agencyId], references: [id], onDelete: Cascade)

  @@index([episodeId])
  @@index([agencyId, createdAt])
  @@index([status])
}

// ============================================================
// Usage + billing
// ============================================================

model UsageLog {
  id           String   @id @default(cuid())
  agencyId     String
  episodeId    String?
  /// Model identifier (e.g. "claude-sonnet-4-6"). Free-form to survive provider changes.
  model        String
  inputTokens  Int
  outputTokens Int
  /// Total cost in USD cents.
  costCents    Int
  createdAt    DateTime @default(now())

  agency  Agency   @relation(fields: [agencyId], references: [id], onDelete: Cascade)
  episode Episode? @relation(fields: [episodeId], references: [id], onDelete: SetNull)

  @@index([agencyId, createdAt])
  @@index([episodeId])
}

model Invoice {
  id               String        @id @default(cuid())
  agencyId         String
  stripeInvoiceId  String        @unique
  amountCents      Int
  currency         String        @default("usd")
  status           InvoiceStatus
  hostedInvoiceUrl String?
  pdfUrl           String?
  periodStart      DateTime
  periodEnd        DateTime
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  agency Agency @relation(fields: [agencyId], references: [id], onDelete: Cascade)

  @@index([agencyId, createdAt])
}

// ============================================================
// Phase 2.13 — Client management & billing support
// ============================================================
//
// SCOPE BOUNDARY: Repodcast never collects, holds, or processes payments
// between an agency and its clients. These tables exist so the agency can
// invoice in its own accounting tool — they store metadata + the
// generated proof-of-work, never card data or transferred funds.

/// 1:1 with `Client` — billing metadata the agency captures for its own
/// records. Surfaced under the "Deliverables & Billing" tab on the client
/// page and consumed by the statement generator + renewals cron.
///
/// `retainerCents` and `ratePerEpisodeCents` are mutually exclusive at the
/// application layer (the form is a radio); both nullable so a brand-new
/// client can exist without one set.
model ClientBillingProfile {
  id                  String       @id @default(cuid())
  clientId            String       @unique
  billingContactName  String?
  billingContactEmail String?
  retainerCents       Int?
  ratePerEpisodeCents Int?
  billingCycle        BillingCycle @default(MONTHLY)
  /// ISO-4217 currency code (e.g. "USD"). Free-form to keep migrations
  /// cheap if we add support for non-listed currencies.
  currency            String       @default("USD")
  contractStartDate   DateTime?
  contractRenewalDate DateTime?
  status              ClientStatus @default(ACTIVE)
  /// External URL the agency lists for its own payment page (Stripe
  /// payment-link, custom checkout, etc.). Surfaced as the only money-shaped
  /// CTA in the client portal — Repodcast does **not** process the payment.
  paymentLinkUrl      String?
  internalNotes       String?
  createdAt           DateTime     @default(now())
  updatedAt           DateTime     @updatedAt

  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  /// Hot path: "list all clients in status X for this agency" — the
  /// renewals cron pivots on `contractRenewalDate` + `status` together.
  @@index([status])
  @@index([contractRenewalDate])
}

/// Persisted snapshot of a generated period statement. Rendered once, then
/// served from R2 thereafter (so the agency + their client get the exact
/// same PDF the agency signed off on, even if the underlying outputs were
/// later edited or removed).
model ClientStatement {
  id                  String    @id @default(cuid())
  clientId            String
  /// Inclusive lower bound of the reporting window.
  periodStart         DateTime
  /// Inclusive upper bound of the reporting window.
  periodEnd           DateTime
  /// Snapshot totals as of `generatedAt`. Each is the count or sum that
  /// fell inside [periodStart, periodEnd]; the PDF/CSV rendered from this
  /// row carries the same numbers forever.
  episodeCount        Int
  outputCount         Int
  approvedCount       Int
  /// 0–100. Stored as Int (percentage rounded) — the UI doesn't surface
  /// sub-percent precision and a decimal column would complicate the JSON
  /// payload the deliverables webhook ships.
  approvalRatePct     Int
  /// Cost-to-serve in USD cents — sum of `UsageLog.costCents` joined via
  /// Episode → Show → Client across the window. Internal, `/root`-only:
  /// the agency-facing surfaces stopped rendering this field with the
  /// statement-line-items rebuild; only platform admins still see it.
  costCents           Int
  /// ISO-4217 currency of this statement's line items. Frozen from the
  /// billing profile at generation time so a later profile currency
  /// change doesn't retroactively alter historical statement rendering.
  /// Defaults to USD so pre-existing rows have a sensible fallback.
  currency            String    @default("USD")
  generatedAt         DateTime  @default(now())
  generatedByMemberId String?
  /// R2 object key for the rendered PDF; null until the renderer finishes.
  pdfStorageKey       String?
  /// R2 object key for the CSV export; null until the export endpoint runs.
  csvStorageKey       String?
  /// Set when the deliverables webhook successfully delivered this row.
  webhookDeliveredAt  DateTime?
  /// Id returned by the agency's webhook handler (e.g. the QuickBooks /
  /// Xero invoice id). Surfaced in the UI as "Delivered to <tool>".
  webhookExternalRef  String?
  /// Phase 3.8 — explicit publish to the client portal. Null keeps the
  /// statement agency-only; setting the timestamp makes it visible on
  /// `/portal/[token]` for any active portal link on this client. An
  /// operator can unshare by nulling both fields — the portal read
  /// re-checks on every render, so revocation is immediate.
  sharedWithPortalAt  DateTime?
  sharedByMemberId    String?

  client            Client                @relation(fields: [clientId], references: [id], onDelete: Cascade)
  generatedByMember Member?               @relation("StatementAuthor", fields: [generatedByMemberId], references: [id], onDelete: SetNull)
  sharedByMember    Member?               @relation("StatementPortalPublisher", fields: [sharedByMemberId], references: [id], onDelete: SetNull)
  items             ClientStatementItem[]

  @@index([clientId, periodStart(sort: Desc)])
  @@index([clientId, generatedAt(sort: Desc)])
  @@index([generatedByMemberId])
  /// Portal list read filters by client + `sharedWithPortalAt IS NOT NULL`
  /// ordered by period. Composite index keeps that pattern seek-only.
  @@index([clientId, sharedWithPortalAt(sort: Desc)])
  @@index([sharedByMemberId])
}

/// Billable line item on a `ClientStatement`. Statements ship with items
/// auto-seeded from the billing profile (retainer and/or rate × episodes);
/// the agency can add, edit, or delete rows to build the invoice they
/// send the client. The sum of `amountCents` is the statement total —
/// what the client owes the agency for the period.
model ClientStatementItem {
  id              String   @id @default(cuid())
  statementId     String
  /// Human-readable line label — e.g. "Monthly retainer", "12 episodes
  /// @ $75", "Extra editing hours". Trimmed to 200 chars at the input.
  description     String
  /// Quantity as a decimal so fractional units (e.g. 0.5 episodes, 2.5
  /// hours) round-trip cleanly. The UI converts to Number on read.
  quantity        Decimal  @db.Decimal(10, 2)
  /// Unit price in the statement's `currency`, in cents. Combined with
  /// `quantity` to derive the row total; stored so the aggregate query
  /// stays a single sum without a Decimal multiplication.
  unitAmountCents Int
  /// Cached `round(quantity × unitAmountCents)`. Written by the server
  /// action every time the row changes so downstream sums stay a single
  /// integer aggregate.
  amountCents     Int
  /// Ascending display order. Ties broken by `createdAt` so a re-order
  /// with duplicate `sortOrder` values still renders deterministically.
  sortOrder       Int      @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  statement ClientStatement @relation(fields: [statementId], references: [id], onDelete: Cascade)

  @@index([statementId, sortOrder])
}

/// Tokenized read-only access to the client portal. Pattern mirrors the
/// homegrown `MemberInvite` flow — opaque cuid token sent to the client out
/// of band; the `/portal/[token]` route lookups go through `getByToken`
/// (public, no `TenantContext`).
model ClientPortalLink {
  id                String    @id @default(cuid())
  clientId          String
  token             String    @unique @default(cuid())
  expiresAt         DateTime
  createdByMemberId String?
  revokedAt         DateTime?
  lastAccessedAt    DateTime?
  /// Optional shared secret. When null, the token alone gates access; when
  /// set, the portal page renders a password form and only accepts the
  /// exact match before showing deliverables. Stored plaintext by design
  /// — it's a short-lived shared secret between agency and client, not
  /// a user account password.
  password          String?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  client          Client                  @relation(fields: [clientId], references: [id], onDelete: Cascade)
  createdByMember Member?                 @relation("PortalLinkAuthor", fields: [createdByMemberId], references: [id], onDelete: SetNull)
  accessLogs      ClientPortalAccessLog[]
  feedback        ClientPortalFeedback[]

  @@index([clientId, expiresAt])
  @@index([createdByMemberId])
}

/// Append-only audit log of portal views. One row per `GET /portal/[token]`
/// that resolves to a live link. `ipHash` is sha-256 of the request IP so
/// we can spot bursts without storing raw IPs; `userAgent` is the bare
/// header string. Both nullable since a real client view in a hardened
/// browser may strip either.
model ClientPortalAccessLog {
  id           String   @id @default(cuid())
  portalLinkId String
  viewedAt     DateTime @default(now())
  ipHash       String?
  userAgent    String?

  portalLink ClientPortalLink @relation(fields: [portalLinkId], references: [id], onDelete: Cascade)

  @@index([portalLinkId, viewedAt(sort: Desc)])
}

/// Feedback submitted by a portal viewer against a specific deliverable
/// (or general feedback when `outputId` is null). Append-only; the agency
/// reads these on the client billing surface. Rate limit + body cap live
/// inline in `submitPortalFeedback` — token is already the access
/// credential, so we don't require an email. `readByMemberId` / `readAt`
/// track when someone on the agency side triaged it.
model ClientPortalFeedback {
  id             String    @id @default(cuid())
  portalLinkId   String
  /// Nullable — general portal feedback isn't tied to any single output.
  outputId       String?
  /// Optional reporter email, captured only when the client volunteers one.
  fromEmail      String?
  /// Free-text body from the portal form. Length-capped in `submitPortalFeedback`.
  body           String
  createdAt      DateTime  @default(now())
  /// Agency-side triage: which member acknowledged the feedback, and when.
  readByMemberId String?
  readAt         DateTime?

  portalLink   ClientPortalLink @relation(fields: [portalLinkId], references: [id], onDelete: Cascade)
  /// Deliberately no FK on outputId — an operator regenerating the output
  /// creates a new row and supersedes the old one; the feedback should stay
  /// visible against the historical version. Nullable + orphan-tolerant.
  readByMember Member?          @relation("PortalFeedbackReader", fields: [readByMemberId], references: [id], onDelete: SetNull)

  @@index([portalLinkId, createdAt(sort: Desc)])
  @@index([outputId])
  @@index([readByMemberId])
}

/// Dedupe ledger for the renewals cron (Phase 2.13.6). The cron fires at the
/// 30-day and 7-day pre-renewal markers; this table makes both fire-exactly-
/// once across daily runs. A row's presence means the email was sent —
/// missing row + window-open = next run sends.
model BillingReminderSent {
  id       String   @id @default(cuid())
  agencyId String
  clientId String
  /// The pre-renewal marker that fired: "30d" or "7d".
  marker   String
  sentAt   DateTime @default(now())

  agency Agency @relation(fields: [agencyId], references: [id], onDelete: Cascade)
  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade, map: "BillingReminderSent_client_fkey")

  @@unique([clientId, marker])
  @@index([agencyId, sentAt])
}

/// Phase 2.10 — dedupe ledger for the onboarding drop-off-recovery cron.
/// The cron fires "finish setup" at 24h and "your first client is waiting"
/// at 72h after `Agency.createdAt` whenever onboarding hasn't finished. A
/// row's presence means that marker has been sent; missing row + window
/// open = next run sends. Same claim-before-send pattern as
/// `BillingReminderSent`.
model OnboardingNudgeSent {
  id       String   @id @default(cuid())
  agencyId String
  /// The drop-off marker that fired: "24h" (finish setup) or "72h" (first client).
  marker   String
  sentAt   DateTime @default(now())

  agency Agency @relation(fields: [agencyId], references: [id], onDelete: Cascade)

  @@unique([agencyId, marker])
  @@index([sentAt])
}

/// Phase 3.9 — dedupe ledger for the mid-trial nudge cron. Currently a
/// single marker (`day_2` — portal-preview nudge halfway through a 7-day
/// trial), but keyed by string so we can add more markers without a
/// migration. Same claim-before-send pattern as `OnboardingNudgeSent`.
model TrialNudgeSent {
  id       String   @id @default(cuid())
  agencyId String
  /// Which mid-trial marker fired. Presently only "day_2" — the day-8
  /// outcome mail is event-driven off Stripe, and the T-3 nudge is driven
  /// by `customer.subscription.trial_will_end`, so no cron for those.
  marker   String
  sentAt   DateTime @default(now())

  agency Agency @relation(fields: [agencyId], references: [id], onDelete: Cascade)

  @@unique([agencyId, marker])
  @@index([sentAt])
}

/// Idempotency ledger for inbound webhooks. Each row marks one provider
/// event as "already processed". The webhook handler `create`s a row before
/// dispatching; a duplicate insert collapses on the unique constraint and
/// the handler short-circuits to 204 (already processed). On dispatch
/// failure we delete the row so the provider's retry re-processes.
///
/// `source` is the provider key — `stripe`, `clerk`, `resend` — so we can
/// dedupe webhooks from every provider through the same table without
/// worrying about cross-provider event-id collisions.
///
/// Rows accumulate forever; a daily prune of `processedAt < now - 90 days`
/// can land as a cron when we see the row count grow (Stripe events older
/// than ~30 days are never retried, so 90 days is a comfortable window).
model WebhookDelivery {
  id          String   @id @default(cuid())
  source      String
  eventId     String
  eventType   String
  processedAt DateTime @default(now())

  @@unique([source, eventId])
  @@index([source, processedAt])
}

// ============================================================
// Phase 3.6 — ROOT user & platform admin backend
// ============================================================
//
// These tables sit ABOVE the tenant graph. A SystemAdmin is a Repodcast
// employee with global access, not a `Member` of any agency. They authenticate
// through Clerk like any other user; the gate is "is there a SystemAdmin row
// for this clerkUserId?", resolved by `server/auth/system.ts`.
//
// SECURITY POSTURE
// - SystemAuditLog is append-only. Every ROOT mutation flows through
//   `withSystemAudit(...)`, which writes the audit row in the SAME prisma
//   $transaction as the mutation. No mutation should ever land without a
//   matching audit row.
// - Soft-delete via `deactivatedAt` so audit FKs survive forever.

/// Platform-employee role granted to a Clerk user via `SystemAdmin`. Distinct
/// from `MemberRole`, which scopes a person inside ONE agency.
///
/// - ROOT     — full mutate access across every tenant (suspend, delete,
///              force-cancel, hard-delete content). Should be 1-2 max in
///              normal operation.
/// - OPERATOR — same read as ROOT; can act on day-to-day support (extend a
///              sub, re-fire a stuck Inngest run, flag a refund). Cannot
///              hard-delete agencies or invoke schema-touching ops.
/// - SUPPORT  — read everything; can initiate read-only impersonation and
///              write to a small surface (resend welcome, regenerate a
///              portal token).
/// - ANALYST  — read everything; NO write access. For finance/BI sharing
///              without the footgun.
enum SystemAdminRole {
  ROOT
  OPERATOR
  SUPPORT
  ANALYST
}

/// One row per Repodcast employee with platform-admin access. Resolved off
/// `clerkUserId`. Same Clerk user may also have `Member` rows in agencies
/// (e.g. the founder also runs a test agency) — the two contexts are looked
/// up independently.
model SystemAdmin {
  id            String          @id @default(cuid())
  /// Clerk user id (`user_…`). Resolved from `auth().userId` in
  /// `getSystemAdminContext`. Unique because each Clerk user maps to at most
  /// one platform-admin identity.
  clerkUserId   String          @unique
  email         String
  name          String?
  role          SystemAdminRole @default(SUPPORT)
  /// When true (default), `/root/*` will redirect to MFA setup if the Clerk
  /// session has no second factor. Off only via direct DB edit; UI never
  /// exposes a toggle so a ROOT can't downgrade their own posture.
  mfaEnforced   Boolean         @default(true)
  /// Last time this admin loaded any `/root/*` page. Updated best-effort in
  /// `requireSystemAdminContext`. Surfaced on the system-admin list for
  /// "who's actually using their access" hygiene.
  lastActiveAt  DateTime?
  /// Soft-delete tombstone. Lookups filter `deactivatedAt: null` so audit
  /// foreign-key history survives.
  deactivatedAt DateTime?
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  authoredAuditEntries   SystemAuditLog[]      @relation("AuditAuthor")
  /// Phase 3.6.11 — SystemConfig rows this admin last wrote. `updatedBy` FK
  /// uses `Restrict` so a soft-delete via `deactivatedAt` is the only teardown
  /// (see the FK block in the migration).
  authoredConfigWrites   SystemConfig[]        @relation("ConfigAuthor")
  /// Phase 3.6.11 — agency plan-limit overrides this admin granted.
  authoredLimitOverrides AgencyLimitOverride[] @relation("LimitOverrideAuthor")
  /// Phase 3.6.10 — abuse reports currently assigned to this admin.
  /// `onDelete: SetNull` on the FK so a soft-delete drops the queue link
  /// without losing the report itself.
  assignedAbuseReports   AbuseReport[]         @relation("AbuseAssignee")
  /// In-app suggestions this admin resolved / shipped / rejected.
  resolvedSuggestions    Suggestion[]          @relation("SuggestionResolver")
  /// Public blog posts this admin is credited as the author on.
  authoredBlogPosts      BlogPost[]            @relation("BlogPostAuthor")
  /// Public blog posts this admin last edited. Separate from author so a
  /// co-owner editing an existing post doesn't overwrite the byline.
  editedBlogPosts        BlogPost[]            @relation("BlogPostEditor")

  @@index([role])
  @@index([deactivatedAt])
}

/// Phase 3.6.16 + 3.6.18 step 4 — nightly rollup of per-agency usage.
///
/// One row per (agency, UTC calendar day). Powers the `/root` overview's
/// hot paths so we stop running `groupBy` on `UsageLog` / `GeneratedOutput`
/// on every dashboard render. The current period (today) still reads live;
/// snapshots cover everything that's closed.
///
/// `date` is anchored to **midnight UTC** for one canonical key per day —
/// the unique constraint enforces "no two snapshots for the same day-agency",
/// which makes the nightly cron safely idempotent (upsert keyed on
/// (agencyId, date) → re-runs update, never duplicate).
///
/// `plan` is snapshotted at write time so the 12-week stacked-bar chart can
/// segment by the plan the agency was ON during that week — a customer
/// upgrading mid-month won't retroactively re-tag their old activity.
///
/// `revenueCents` rolls up PAID invoices' `amountCents`. Mixed-currency rows
/// would normally need conversion, but every Stripe invoice we ingest is
/// already in the agency's `preferredCurrency` and we don't currently
/// aggregate across agencies in non-USD reporting — see PLAN §3.6.7 for the
/// multi-currency cohort note.
model AgencyUsageSnapshot {
  id           String   @id @default(cuid())
  agencyId     String
  /// 00:00 UTC of the day this snapshot represents.
  date         DateTime
  /// The agency's plan at snapshot time.
  plan         Plan
  /// New episodes created on this UTC day, scoped to the agency.
  episodes     Int      @default(0)
  /// New current-version outputs created on this UTC day (excludes superseded).
  outputs      Int      @default(0)
  /// Sum of `UsageLog.costCents` for this UTC day.
  costCents    Int      @default(0)
  /// Sum of PAID invoices' `amountCents` for this UTC day.
  revenueCents Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  agency Agency @relation(fields: [agencyId], references: [id], onDelete: Cascade)

  /// One snapshot per agency-day. Backs the cron's idempotent upsert.
  @@unique([agencyId, date])
  /// Hot path for date-range aggregates ("sum for the current month").
  @@index([date])
  /// Hot path for per-agency time series ("show me this agency's last 90d").
  @@index([agencyId, date(sort: Desc)])
}

/// Append-only audit log of every ROOT-side write. Inserted in the SAME
/// `prisma.$transaction` as the mutation it describes, via the
/// `withSystemAudit(...)` wrapper. If the mutation rolls back, the audit row
/// rolls back too — and vice versa. There is no "wrote but didn't log" path.
///
/// The action key is a free-form dotted string (e.g. `agency.suspend`,
/// `member.impersonate`, `subscription.force_cancel`) keyed off a const map
/// in `server/db/system/audit-actions.ts` so the TS layer enforces consistency
/// while the column stays migration-stable.
///
/// `before` / `after` snapshot the row(s) touched. Stored as Json so we can
/// capture arbitrarily-shaped pre/post images without inventing a column.
model SystemAuditLog {
  id               String   @id @default(cuid())
  bySystemAdminId  String
  /// Dotted action key. See `server/db/system/audit-actions.ts`.
  action           String
  targetAgencyId   String?
  targetMemberId   String?
  /// Free-form entity-type tag (e.g. "agency", "subscription", "member"). Pairs
  /// with `targetEntityId` so we can audit rows the schema doesn't have a
  /// dedicated FK column for.
  targetEntityType String?
  targetEntityId   String?
  before           Json?
  after            Json?
  /// Free-text reason the operator typed in the confirm dialog. Required for
  /// destructive actions at the action layer.
  note             String?
  /// Source IP at the time of the action. Raw (not hashed) — this is internal
  /// audit, not user-facing telemetry. Stripped to first non-trusted-proxy hop
  /// at the action layer.
  ipAddress        String?
  userAgent        String?
  createdAt        DateTime @default(now())

  bySystemAdmin SystemAdmin @relation("AuditAuthor", fields: [bySystemAdminId], references: [id], onDelete: Restrict)

  @@index([bySystemAdminId, createdAt(sort: Desc)])
  @@index([targetAgencyId, createdAt(sort: Desc)])
  @@index([action, createdAt(sort: Desc)])
  @@index([createdAt(sort: Desc)])
}

// ============================================================
// Phase 3.6.11 — Platform configuration + per-agency overrides
// ============================================================
//
// SystemConfig is a flat key/value bag for platform-wide toggles that don't
// warrant their own column (feature flags not shipped through PostHog,
// Anthropic model defaults, cost-cap overrides per plan, the CAC entry for
// LTV:CAC, marketing copy). `value` is Json so an operator can change a
// value's SHAPE without a schema migration; the audit log's before/after
// captures every mutation.
//
// AgencyLimitOverride grants a specific agency a resource ceiling different
// from its plan's default (e.g. "give Acme 100 episodes/month even though
// they're on STUDIO"). Consumed by `planCapacity()` in
// `server/billing/limits.ts`.

/// Which of the four metered resources an override applies to. Mirrors the
/// `LimitedResource` union in `server/billing/limits.ts`; keep them in sync.
enum LimitOverrideResource {
  SHOWS
  MEMBERS
  EPISODES
  GENERATIONS
}

/// Flat key/value bag for platform-wide toggles. See §3.6.11.
///
/// - `key` is the operator-facing identifier (e.g. `RSS_IMPORT_ENABLED`,
///   `CAC_USD_MONTHLY`, `ANTHROPIC_DEFAULT_MODEL`). No enum — arbitrary keys
///   land here so we don't need a migration per new config surface.
/// - `value` is Json to survive shape changes. Callers cast on read; the
///   admin UI edits raw JSON so mistakes surface loudly.
/// - `updatedBySystemAdminId` is Restrict on delete so audit attribution
///   survives even if a ROOT is soft-deleted. Nullable so the initial
///   bootstrap seed (no admin yet) can still write rows.
model SystemConfig {
  id                     String   @id @default(cuid())
  key                    String   @unique
  value                  Json
  /// Free-text description of what the key controls. Rendered in the admin
  /// UI so the next operator doesn't have to grep the codebase to find out
  /// what `RSS_IMPORT_ENABLED` gates.
  description            String?
  updatedBySystemAdminId String?
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt

  updatedBy SystemAdmin? @relation("ConfigAuthor", fields: [updatedBySystemAdminId], references: [id], onDelete: Restrict)

  @@index([updatedBySystemAdminId])
}

/// Per-agency resource-limit override. One row per (agencyId, resource) at a
/// time — the operator updates the row to change the value, sets `expiresAt`
/// to end it, or hard-deletes to revoke immediately (with an audit note).
///
/// Consumed by `planCapacity()`: if a live row exists for a resource and its
/// `expiresAt` hasn't passed, its `value` replaces the plan default. If the
/// override is LOWER than the plan default, that's intentional — operators
/// use it to cap an abusing agency without downgrading the plan.
model AgencyLimitOverride {
  id              String                @id @default(cuid())
  agencyId        String
  resource        LimitOverrideResource
  /// New cap for the resource. Absolute value — not additive on top of the
  /// plan default. `0` = fully disable the resource for this agency.
  value           Int
  /// When the override stops applying. Null = indefinite. Past-timestamped
  /// rows are ignored by `planCapacity()` but retained for audit.
  expiresAt       DateTime?
  /// Free-text reason (e.g. "comp for support case #123"). Surfaced in the
  /// admin table + captured on the initial audit row.
  note            String?
  bySystemAdminId String
  createdAt       DateTime              @default(now())
  updatedAt       DateTime              @updatedAt

  agency Agency      @relation(fields: [agencyId], references: [id], onDelete: Cascade)
  by     SystemAdmin @relation("LimitOverrideAuthor", fields: [bySystemAdminId], references: [id], onDelete: Restrict)

  /// One live override per (agency, resource). Editing an existing override
  /// updates the row in place; audit captures the history.
  @@unique([agencyId, resource])
  @@index([expiresAt])
  @@index([bySystemAdminId])
}

// ============================================================
// Phase 3.6.10 — Quality, abuse, and moderation
// ============================================================
//
// AbuseReport is the durable queue for inbound complaints — spam, copyright,
// brand impersonation, harassment. Two ingress paths (both funnel into the
// same table):
//   1. Public `/legal/report` form (Phase 4 — inbound anonymous). Populates
//      `reportedByEmail` from the form.
//   2. Manual entry by a ROOT / OPERATOR from `/root/quality` — for phoned-in
//      complaints logged after the fact. `reportedByEmail` may be null.
//
// The `target*` columns are plain nullable Strings — no FK — so hard-deleting
// an agency, member, or output doesn't cascade-wipe reports that referenced
// it. Same posture as `SystemAuditLog.targetAgencyId`.

/// Category the reporter picked (or the intake operator inferred).
enum AbuseReportCategory {
  SPAM
  COPYRIGHT
  IMPERSONATION
  HARASSMENT
  OTHER
}

/// Triage state. `OPEN` = untouched, `IN_REVIEW` = an operator is on it,
/// `RESOLVED` = action taken (see `resolution`), `DISMISSED` = no action
/// needed (e.g. wrong URL, spam-of-a-report). Both terminal states stamp
/// `resolvedAt`.
enum AbuseReportStatus {
  OPEN
  IN_REVIEW
  RESOLVED
  DISMISSED
}

model AbuseReport {
  id                      String              @id @default(cuid())
  /// Reporter's email as provided on the intake form. Nullable so a phoned-in
  /// complaint logged manually still lands here.
  reportedByEmail         String?
  category                AbuseReportCategory
  /// Free-text complaint body from the intake form.
  body                    String
  status                  AbuseReportStatus   @default(OPEN)
  /// Nullable target pointers — no FK (see the header note).
  targetAgencyId          String?
  targetMemberId          String?
  targetOutputId          String?
  /// The SystemAdmin currently on it. Set when triage flips to IN_REVIEW /
  /// RESOLVED / DISMISSED.
  assignedToSystemAdminId String?
  /// Free-text summary of what the operator did (used the "resolve" action).
  /// Null on OPEN / IN_REVIEW / DISMISSED.
  resolution              String?
  createdAt               DateTime            @default(now())
  /// Stamped when status flips to RESOLVED or DISMISSED.
  resolvedAt              DateTime?
  updatedAt               DateTime            @updatedAt

  assignedTo SystemAdmin? @relation("AbuseAssignee", fields: [assignedToSystemAdminId], references: [id], onDelete: SetNull)

  /// Queue hot path: paginated OPEN list sorted by age.
  @@index([status, createdAt])
  @@index([assignedToSystemAdminId, status])
  @@index([targetAgencyId, createdAt])
  @@index([category, status])
}

/// Phase 3.3 — per-agency scheduling-provider connection. Currently only
/// Buffer, but the shape is provider-generic so Typefully or a future
/// first-party integration slots in without a migration. `accessToken` is
/// AES-256-GCM encrypted at the app layer (see `server/crypto/token-vault.ts`)
/// — nothing else in this table is secret. `meta` holds provider-specific
/// bookkeeping such as Buffer profile ids keyed by our `Platform` enum.
model AgencyIntegration {
  id                  String            @id @default(cuid())
  agencyId            String
  provider            ExternalScheduler
  /// Encrypted, opaque to callers — always route through the token vault.
  accessToken         String
  /// Only populated on providers with refreshable tokens (Buffer v2 / OAuth 2).
  refreshToken        String?
  expiresAt           DateTime?
  /// Provider-specific bag. For Buffer: `{ profiles: { TWITTER: "abc123", ... } }`.
  meta                Json?
  /// Per-agency setting: auto-flip SCHEDULED → PUBLISHED for MANUAL rows
  /// whose `scheduledFor` is past. Buffer-backed rows always sync from the
  /// provider regardless of this flag.
  autoMarkPublished   Boolean           @default(true)
  connectedByMemberId String?
  lastSyncedAt        DateTime?
  lastSyncError       String?
  createdAt           DateTime          @default(now())
  updatedAt           DateTime          @updatedAt

  agency      Agency  @relation(fields: [agencyId], references: [id], onDelete: Cascade)
  connectedBy Member? @relation("IntegrationConnector", fields: [connectedByMemberId], references: [id], onDelete: SetNull)

  /// One row per (agency, provider) — a second connect from the same agency
  /// overwrites the token via upsert rather than creating a duplicate row.
  @@unique([agencyId, provider])
  @@index([agencyId])
}

// ============================================================
// In-app suggestions / feedback (Bug, Request, Improvement, …)
// ============================================================
//
// User-submitted feedback captured from the dashboard's floating Feedback
// button. The row is the durable source of truth; a Resend email to the
// feedback inbox is fire-and-forget so a Resend hiccup can never fail the
// submission itself.
//
// FK posture mirrors AbuseReport pointers (nullable + SetNull) so hard-
// deleting an agency or removing a member doesn't cascade-wipe historical
// feedback — the queue on `/root/feedback` still renders the row with a
// snapshotted `reporterEmail`/`reporterName`.

model Suggestion {
  id                      String           @id @default(cuid())
  /// Agency the reporter belonged to at submission. Null when the
  /// reporter had no active membership; historical rows also null-out
  /// on agency hard-delete.
  agencyId                String?
  /// Member row of the reporter. Same nullability + SetNull rationale as
  /// `agencyId`.
  memberId                String?
  /// Snapshotted at submit time so the row still reads correctly after
  /// the member is removed from the agency.
  reporterEmail           String
  reporterName            String?
  type                    SuggestionType
  /// One-line summary — length-capped in the create input.
  title                   String
  /// Free-text body — length-capped in the create input.
  body                    String
  status                  SuggestionStatus @default(NEW)
  /// The pathname the reporter was on when they hit "Send feedback".
  /// Helps operators reproduce a bug or eyeball a feature request in
  /// context. Free-form; validated to `startsWith("/")` at input.
  contextUrl              String?
  /// Free-text resolution note the operator typed when moving the row
  /// to `SHIPPED` or `WONTFIX`. Null on non-terminal states.
  resolution              String?
  resolvedAt              DateTime?
  resolvedBySystemAdminId String?
  createdAt               DateTime         @default(now())
  updatedAt               DateTime         @updatedAt

  agency                Agency?      @relation(fields: [agencyId], references: [id], onDelete: SetNull)
  member                Member?      @relation(fields: [memberId], references: [id], onDelete: SetNull)
  resolvedBySystemAdmin SystemAdmin? @relation("SuggestionResolver", fields: [resolvedBySystemAdminId], references: [id], onDelete: SetNull)

  /// Queue hot path: paginated queue sorted by (status, age).
  @@index([status, createdAt])
  /// Filter-dropdown hot path on `/root/feedback`.
  @@index([type, status])
  /// "All feedback from agency X" drill-in.
  @@index([agencyId, createdAt])
  @@index([resolvedBySystemAdminId])
}

// ============================================================
// Public blog — SEO-optimised marketing surface
// ============================================================
//
// Authored ONLY by SystemAdmins from `/root/blog`. There is no user-generated
// content path; the XSS surface is limited to what the authoring admin types
// in themselves, and the Markdown renderer never emits raw HTML.
//
// Every write flows through `withSystemAudit` (see `server/db/system/blog.ts`)
// so the SystemAuditLog captures the before/after row.

/// Lifecycle state of a `BlogPost`. `PUBLISHED` = live on `/blog/[slug]`,
/// `SCHEDULED` = has a future `publishedAt`; the public reader treats
/// scheduled + past-scheduled rows the same as `PUBLISHED` (no cron; a
/// scheduled row goes live when its publishedAt passes).
enum BlogPostStatus {
  DRAFT
  SCHEDULED
  PUBLISHED
  ARCHIVED
}

model BlogPost {
  id                String         @id @default(cuid())
  /// URL slug. Kebab-case, unique across the whole table — surfaces at
  /// `/blog/<slug>` so the shape has to match a URL segment. Enforced via
  /// regex at the input layer.
  slug              String         @unique
  /// Public title. Renders as `<h1>` on the post page and in `<title>` when
  /// `metaTitle` is empty.
  title             String
  /// Short summary shown on the index card, in the OG description fallback,
  /// and inside the `<meta name="description">` when `metaDescription`
  /// is blank.
  excerpt           String
  /// Markdown body. Rendered to HTML on the server via `lib/markdown.ts` — a
  /// deliberately narrow safe-subset renderer (no raw HTML). If we ever open
  /// the authoring surface to lower-trust roles, this stops being safe.
  bodyMarkdown      String
  /// R2 / CDN URL for the hero image. Used as OG image fallback. Optional so
  /// the earliest posts can ship without imagery.
  coverImageUrl     String?
  /// Author-set category tag ("engineering", "voice", "case-study"). Free-form
  /// String — no relation — so a rename is a string edit, not a migration.
  category          String?
  /// Free-form tag list. Rendered on the post + used for the "related posts"
  /// heuristic (shared tag count).
  tags              String[]
  /// Rough English-content read-time in minutes; the admin can override, else
  /// we compute from `bodyMarkdown.split(/\s+/).length / 220`.
  readingMinutes    Int?
  status            BlogPostStatus @default(DRAFT)
  /// Original publish timestamp. When status = PUBLISHED and this is in the
  /// past, the post is live. When status = SCHEDULED with a future date, the
  /// public reader ignores it until the date passes.
  publishedAt       DateTime?
  /// SEO override for the `<title>`. Falls back to `title` when null.
  metaTitle         String?
  /// SEO override for `<meta name="description">`. Falls back to `excerpt`.
  metaDescription   String?
  /// Overrides the canonical link when the post is syndicated from / to
  /// another site. Absolute URL. Null → the post's own `/blog/<slug>` URL.
  canonicalUrl      String?
  /// Explicit noindex flag. When true, `robots: { index: false, follow: true }`
  /// is emitted on the post's metadata.
  noindex           Boolean        @default(false)
  /// SEO keyword list (`<meta name="keywords">`). Advisory only for modern
  /// engines; still surfaced because niche crawlers use it.
  keywords          String[]
  /// Optional override for the JSON-LD `<script>` block. When null, the page
  /// emits the default Article schema built from the row itself. When set,
  /// this JSON is emitted as-is — used when the author needs to add
  /// `FAQPage`, `HowTo`, or fine-grained authors.
  structuredDataJson Json?

  /// Public page-view counter. Incremented atomically by
  /// `POST /api/blog/[slug]/view` on beacon requests from the reader; the
  /// counter is best-effort (bot-guarded + session-deduped, not
  /// cryptographically hardened) and used for editorial signal only.
  viewCount Int @default(0)

  /// Public upvote counter — anonymous, one vote per browser (dedup via
  /// `localStorage` on the client). Incremented by `POST` and decremented
  /// by `DELETE` on `/api/blog/[slug]/upvote`. Same best-effort posture as
  /// `viewCount`; floored at 0 by the write helper so a rogue DELETE loop
  /// can't push it negative.
  upvoteCount Int @default(0)

  authorAdminId    String?
  updatedByAdminId String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  author    SystemAdmin? @relation("BlogPostAuthor", fields: [authorAdminId], references: [id], onDelete: SetNull)
  updatedBy SystemAdmin? @relation("BlogPostEditor", fields: [updatedByAdminId], references: [id], onDelete: SetNull)

  /// Public reader hot path: recent PUBLISHED posts in publish order.
  @@index([status, publishedAt(sort: Desc)])
  /// Category-drilldown hot path.
  @@index([category, publishedAt(sort: Desc)])
  @@index([authorAdminId])
  @@index([updatedByAdminId])
}
