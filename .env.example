# ============================================================
# Repodcast — environment contract
# Copy to .env.local (gitignored) and fill in real values.
# This file (.env.example) is committed and must contain NO secrets.
# ============================================================

# ------------------------------------------------------------
# App URL
# Absolute origin the app links back to (webhooks, OAuth callbacks,
# email deep-links). Vercel deployments fall back to VERCEL_URL when unset.
# ------------------------------------------------------------
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# ------------------------------------------------------------
# Core — required to boot the app
# ------------------------------------------------------------

# Database (Neon Postgres)
# DATABASE_URL: pooled (PgBouncer) connection used by the app at runtime.
# DIRECT_URL:   unpooled direct connection used by `prisma migrate` only.
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DB?sslmode=require&pgbouncer=true"
DIRECT_URL="postgresql://USER:PASSWORD@HOST/DB?sslmode=require"

# Auth (Clerk)
# Note: placeholders are deliberately NOT the real key format
# (e.g. "sk_test_<base62>") — GitHub's secret-scanning treats the format
# itself as a leak even when the value is bogus. Use the Clerk dashboard's
# actual values in .env.local.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY="<clerk-publishable-key>"
CLERK_SECRET_KEY="<clerk-secret-key>"
CLERK_WEBHOOK_SECRET="<clerk-webhook-signing-secret>"

# ------------------------------------------------------------
# AI & transcription
# ------------------------------------------------------------
ANTHROPIC_API_KEY="<anthropic-api-key>"
DEEPGRAM_API_KEY="<deepgram-api-key>"

# ------------------------------------------------------------
# Background jobs (Inngest)
# INNGEST_DEV=1 runs the local dev server; remove/set 0 in production.
# ------------------------------------------------------------
INNGEST_EVENT_KEY="<inngest-event-key>"
INNGEST_SIGNING_KEY="<inngest-signing-key>"
INNGEST_DEV="1"

# ------------------------------------------------------------
# Billing (Stripe)
# Each plan has ONE Stripe Price with `currency_options` for every code in
# `lib/currencies.ts` (USD / EUR / GBP / CAD / AUD). Checkout picks the
# currency at session time. Run `npm run stripe:plans` to bootstrap the
# Products + multi-currency Prices and print the IDs.
# ------------------------------------------------------------
STRIPE_SECRET_KEY="<stripe-secret-key>"
STRIPE_WEBHOOK_SECRET="<stripe-webhook-signing-secret>"
# One Price per (plan, cadence). `npm run stripe:plans` provisions all six
# and prints the IDs ready to paste. Annual = monthly × 10 ("two months free").
NEXT_PUBLIC_STRIPE_STUDIO_MONTHLY_PRICE_ID="<stripe-studio-monthly-price-id>"
NEXT_PUBLIC_STRIPE_STUDIO_ANNUAL_PRICE_ID="<stripe-studio-annual-price-id>"
NEXT_PUBLIC_STRIPE_AGENCY_MONTHLY_PRICE_ID="<stripe-agency-monthly-price-id>"
NEXT_PUBLIC_STRIPE_AGENCY_ANNUAL_PRICE_ID="<stripe-agency-annual-price-id>"
NEXT_PUBLIC_STRIPE_NETWORK_MONTHLY_PRICE_ID="<stripe-network-monthly-price-id>"
NEXT_PUBLIC_STRIPE_NETWORK_ANNUAL_PRICE_ID="<stripe-network-annual-price-id>"

# ------------------------------------------------------------
# Transactional email (Resend)
# RESEND_FROM_EMAIL: RFC 5322 "Name <local@domain>" form. Domain MUST be
# verified in Resend for the environment's API key. Tag non-prod display names.
#   Prod:    Repodcast <no-reply@repodcastapp.com>
#   Staging: Repodcast (staging) <no-reply@repodcastapp.com>
#   Local:   Repodcast (dev) <no-reply@repodcastapp.com>
# ------------------------------------------------------------
RESEND_API_KEY="<resend-api-key>"
RESEND_FROM_EMAIL="Repodcast <no-reply@repodcastapp.com>"

# ------------------------------------------------------------
# Storage (Cloudflare R2)
# Bucket is PRIVATE; audio is read via presigned URLs.
# Endpoint is derived: https://${R2_ACCOUNT_ID}.r2.cloudflarestorage.com
# ------------------------------------------------------------
R2_ACCOUNT_ID="<r2-account-id>"
R2_ACCESS_KEY_ID="<r2-access-key-id>"
R2_SECRET_ACCESS_KEY="<r2-secret-access-key>"
R2_BUCKET="repodcast-dev"
# Public base URL for the bucket — required for artwork upload (composes
# `${base}/${objectKey}`). Audio is always served via presigned URLs, never
# this domain. Use either the bucket's pub-*.r2.dev endpoint or a bound
# custom domain. MUST point at the same bucket as R2_BUCKET.
NEXT_PUBLIC_R2_PUBLIC_BASE_URL="https://pub-xxxxxxxx.r2.dev"

# ------------------------------------------------------------
# Imports (RSS / YouTube)
# ------------------------------------------------------------
PODCAST_INDEX_KEY="<podcast-index-key>"
PODCAST_INDEX_SECRET="<podcast-index-secret>"

# ------------------------------------------------------------
# Observability (PostHog + Sentry)
# POSTHOG_HOST: defaults to https://us.i.posthog.com (use eu. if EU project).
# ------------------------------------------------------------
NEXT_PUBLIC_POSTHOG_KEY="<posthog-project-key>"
NEXT_PUBLIC_POSTHOG_HOST="https://us.i.posthog.com"

NEXT_PUBLIC_SENTRY_DSN="<sentry-dsn>"
SENTRY_DSN="<sentry-dsn>"

# ------------------------------------------------------------
# CI / build-only (Sentry source-map upload) — set in Vercel/CI, not locally
# ------------------------------------------------------------
SENTRY_ORG=""
SENTRY_PROJECT=""
SENTRY_AUTH_TOKEN=""

# ------------------------------------------------------------
# Platform admin bootstrap (Phase 3.6.1)
#
# Used by `npm run admin:bootstrap-root` to mint the first SystemAdmin row
# with role=ROOT. Idempotent — re-running upserts the row + clears
# `deactivatedAt`. Subsequent admins are minted from `/root/config` (3.6.11)
# so every mutation flows through `withSystemAudit`.
#
# Steps:
#   1. Sign up / sign in the operator via the normal /sign-in route.
#   2. In Clerk dashboard, copy their user_id (`user_…`).
#   3. Paste it as ROOT_BOOTSTRAP_CLERK_USER_ID in .env.local.
#   4. `npm run admin:bootstrap-root`.
#   5. Visit /root — the gate resolves the user as ROOT.
#
# MFA enforcement is deferred — the `mfaEnforced` column lands on every row
# (default true), but the runtime gate is a no-op until 3.6.6 wires it
# against `clerkClient.users.getUser().twoFactorEnabled`. You can sign in
# without a second factor today; we'll flip the check on as part of the
# impersonation slice.
# ------------------------------------------------------------
ROOT_BOOTSTRAP_EMAIL=hdemsongtsamo@gmail.com
ROOT_BOOTSTRAP_CLERK_USER_ID=user_xxxxxxxxxxxx
# Optional display name on the SystemAdmin row.
ROOT_BOOTSTRAP_NAME="Herman Demsong"

# ------------------------------------------------------------
# Impersonation signing key (Phase 3.6.6)
#
# 32+ byte secret used to HMAC-sign the read-only impersonation cookie.
# Signed server-side, verified in constant time on every dashboard render.
# Rotate by changing the value: all live envelopes invalidate immediately.
# Generate: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
# ------------------------------------------------------------
IMPERSONATION_SIGNING_KEY="<impersonation-signing-key>"

# ------------------------------------------------------------
# Scheduling integrations (Phase 3.3 — Buffer / Typefully)
#
# INTEGRATION_ENCRYPTION_KEY: 32-byte base64. Encrypts OAuth access tokens
#   at rest. Generate: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
#
# BUFFER_CLIENT_ID / _SECRET: register an app at https://buffer.com/developers/apps.
#   Callback URL: ${NEXT_PUBLIC_APP_URL}/api/integrations/buffer/callback.
# BUFFER_REDIRECT_URI: optional override (needed when tunneling via ngrok).
# ------------------------------------------------------------
INTEGRATION_ENCRYPTION_KEY="<integration-encryption-key-32-byte-base64>"
BUFFER_CLIENT_ID="<buffer-client-id>"
BUFFER_CLIENT_SECRET="<buffer-client-secret>"
# BUFFER_REDIRECT_URI="https://yourapp.example.com/api/integrations/buffer/callback"
# BUFFER_TOKEN_URL="https://auth.buffer.com/token"
# BUFFER_API_URL="https://api.buffer.com"

# ------------------------------------------------------------
# Public contact addresses (marketing + legal surfaces)
# Rendered into HTML by /about, /contact, /legal/*, and the landing
# footer. Optional — omit to use the @repodcastapp.com defaults baked
# into lib/contact-emails.ts.
# ------------------------------------------------------------
CONTACT_EMAIL_HELLO="hello@repodcastapp.com"
CONTACT_EMAIL_SUPPORT="support@repodcastapp.com"
CONTACT_EMAIL_PRIVACY="privacy@repodcastapp.com"
CONTACT_EMAIL_SECURITY="security@repodcastapp.com"
CONTACT_EMAIL_LEGAL="legal@repodcastapp.com"