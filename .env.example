# ============================================================
# Repodcast — environment contract
# Copy to .env.local (gitignored) and fill in real values.
# This file (.env.example) is committed and must contain NO secrets.
# ============================================================

# ------------------------------------------------------------
# Core — required to boot the app
# ------------------------------------------------------------

# Database (Neon Postgres)
# DATABASE_URL: pooled (PgBouncer) connection used by the app at runtime.
# DIRECT_URL:   unpooled direct connection used by `prisma migrate` only.
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DB?sslmode=require&pgbouncer=true"
DIRECT_URL="postgresql://USER:PASSWORD@HOST/DB?sslmode=require"

# Auth (Clerk)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY="pk_test_xxxxxxxxxxxxxxxxxxxxxxxx"
CLERK_SECRET_KEY="sk_test_xxxxxxxxxxxxxxxxxxxxxxxx"
CLERK_WEBHOOK_SIGNING_SECRET="whsec_xxxxxxxxxxxxxxxxxxxxxxxx"

# ------------------------------------------------------------
# AI & transcription
# ------------------------------------------------------------
ANTHROPIC_API_KEY="sk-ant-apiXX-xxxxxxxxxxxxxxxxxxxxxxxx"
DEEPGRAM_API_KEY="xxxxxxxxxxxxxxxxxxxxxxxx"

# ------------------------------------------------------------
# Background jobs (Inngest)
# INNGEST_DEV=1 runs the local dev server; remove/set 0 in production.
# ------------------------------------------------------------
INNGEST_EVENT_KEY="xxxxxxxxxxxxxxxxxxxxxxxx"
INNGEST_SIGNING_KEY="signkey-prod-xxxxxxxxxxxxxxxxxxxxxxxx"
INNGEST_DEV="1"

# ------------------------------------------------------------
# Billing (Stripe)
# Each plan has ONE Stripe Price with `currency_options` for every code in
# `lib/currencies.ts` (USD / EUR / GBP / CAD / AUD). Checkout picks the
# currency at session time. Run `npm run stripe:plans` to bootstrap the
# Products + multi-currency Prices and print the IDs.
# ------------------------------------------------------------
STRIPE_SECRET_KEY="sk_test_xxxxxxxxxxxxxxxxxxxxxxxx"
STRIPE_WEBHOOK_SECRET="whsec_xxxxxxxxxxxxxxxxxxxxxxxx"
# One Price per (plan, cadence). `npm run stripe:plans` provisions all six
# and prints the IDs ready to paste. Annual = monthly × 10 ("two months free").
NEXT_PUBLIC_STRIPE_STUDIO_MONTHLY_PRICE_ID="price_xxxxxxxxxxxx"
NEXT_PUBLIC_STRIPE_STUDIO_ANNUAL_PRICE_ID="price_xxxxxxxxxxxx"
NEXT_PUBLIC_STRIPE_AGENCY_MONTHLY_PRICE_ID="price_xxxxxxxxxxxx"
NEXT_PUBLIC_STRIPE_AGENCY_ANNUAL_PRICE_ID="price_xxxxxxxxxxxx"
NEXT_PUBLIC_STRIPE_NETWORK_MONTHLY_PRICE_ID="price_xxxxxxxxxxxx"
NEXT_PUBLIC_STRIPE_NETWORK_ANNUAL_PRICE_ID="price_xxxxxxxxxxxx"

# ------------------------------------------------------------
# Transactional email (Resend)
# ------------------------------------------------------------
RESEND_API_KEY="re_xxxxxxxxxxxxxxxxxxxxxxxx"

# ------------------------------------------------------------
# Storage (Cloudflare R2)
# Bucket is PRIVATE; audio is read via presigned URLs.
# Endpoint is derived: https://${R2_ACCOUNT_ID}.r2.cloudflarestorage.com
# ------------------------------------------------------------
R2_ACCOUNT_ID="xxxxxxxxxxxxxxxxxxxxxxxx"
R2_ACCESS_KEY_ID="xxxxxxxxxxxxxxxxxxxxxxxx"
R2_SECRET_ACCESS_KEY="xxxxxxxxxxxxxxxxxxxxxxxx"
R2_BUCKET="repodcast-dev"
# Optional. ONLY set if a bucket is intentionally public (it should not be for audio).
# NEXT_PUBLIC_R2_PUBLIC_BASE_URL="https://pub-xxxxxxxx.r2.dev"

# ------------------------------------------------------------
# Imports (RSS / YouTube)
# ------------------------------------------------------------
PODCAST_INDEX_KEY="xxxxxxxxxxxxxxxxxxxxxxxx"
PODCAST_INDEX_SECRET="xxxxxxxxxxxxxxxxxxxxxxxx"

# ------------------------------------------------------------
# Observability (PostHog + Sentry)
# POSTHOG_HOST: defaults to https://us.i.posthog.com (use eu. if EU project).
# ------------------------------------------------------------
NEXT_PUBLIC_POSTHOG_KEY="phc_xxxxxxxxxxxxxxxxxxxxxxxx"
NEXT_PUBLIC_POSTHOG_HOST="https://us.i.posthog.com"

NEXT_PUBLIC_SENTRY_DSN="https://xxxxxxxx@oXXXXX.ingest.us.sentry.io/XXXXX"
SENTRY_DSN="https://xxxxxxxx@oXXXXX.ingest.us.sentry.io/XXXXX"

# ------------------------------------------------------------
# CI / build-only (Sentry source-map upload) — set in Vercel/CI, not locally
# ------------------------------------------------------------
SENTRY_ORG=""
SENTRY_PROJECT=""
SENTRY_AUTH_TOKEN=""

# ------------------------------------------------------------
# Platform admin bootstrap (Phase 3.6.1)
#
# Used by `npm run admin:bootstrap-root` to mint the first SystemAdmin row
# with role=ROOT. Idempotent — re-running upserts the row + clears
# `deactivatedAt`. Subsequent admins are minted from `/root/config` (3.6.11)
# so every mutation flows through `withSystemAudit`.
#
# Steps:
#   1. Sign up / sign in the operator via the normal /sign-in route.
#   2. In Clerk dashboard, copy their user_id (`user_…`).
#   3. Paste it as ROOT_BOOTSTRAP_CLERK_USER_ID in .env.local.
#   4. `npm run admin:bootstrap-root`.
#   5. Visit /root — the gate resolves the user as ROOT.
#
# MFA enforcement is deferred — the `mfaEnforced` column lands on every row
# (default true), but the runtime gate is a no-op until 3.6.6 wires it
# against `clerkClient.users.getUser().twoFactorEnabled`. You can sign in
# without a second factor today; we'll flip the check on as part of the
# impersonation slice.
# ------------------------------------------------------------
ROOT_BOOTSTRAP_EMAIL=hdemsongtsamo@gmail.com
ROOT_BOOTSTRAP_CLERK_USER_ID=user_xxxxxxxxxxxx
# Optional display name on the SystemAdmin row.
ROOT_BOOTSTRAP_NAME="Herman Demsong"

# ------------------------------------------------------------
# Impersonation signing key (Phase 3.6.6)
#
# 32+ byte secret used to HMAC-sign the read-only impersonation cookie.
# Cookie format: `<base64url(payload)>.<base64url(hmac-sha256)>` — signed
# server-side, verified in constant time on every dashboard render. Without
# this set, the start action redirects with `impersonate_error=signing_key_missing`
# and no audit row is written.
#
# Rotate by changing the value: all live envelopes invalidate immediately
# (signatures stop verifying), forcing operators to re-impersonate.
#
# Generate: `node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"`
# ------------------------------------------------------------
IMPERSONATION_SIGNING_KEY="set-a-long-random-32-plus-byte-secret"

# ------------------------------------------------------------
# Phase 3.3 — Scheduling integrations
# ------------------------------------------------------------
#
# INTEGRATION_ENCRYPTION_KEY: 32-byte base64. Used to encrypt Buffer /
# Typefully OAuth access tokens at rest. Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
INTEGRATION_ENCRYPTION_KEY="set-a-32-byte-base64-secret"

# Buffer OAuth 2 credentials — register an app at
# https://buffer.com/developers/apps and paste the Client ID + Secret here.
# Set the app's Callback URL to `${NEXT_PUBLIC_APP_URL}/api/integrations/buffer/callback`.
BUFFER_CLIENT_ID=""
BUFFER_CLIENT_SECRET=""

# Optional overrides. When unset, the app derives redirect_uri from
# NEXT_PUBLIC_APP_URL and points at Buffer's default endpoints.
# BUFFER_REDIRECT_URI="https://yourapp.example.com/api/integrations/buffer/callback"
# BUFFER_TOKEN_URL="https://auth.buffer.com/token"
# BUFFER_API_URL="https://api.buffer.com"

# ------------------------------------------------------------
# Public contact addresses (marketing + legal surfaces)
# Rendered into HTML by /about, /contact, /legal/*, and the landing
# footer. Optional — omit to use the @repodcast.io defaults baked into
# lib/contact-emails.ts.
# ------------------------------------------------------------
# CONTACT_EMAIL_HELLO="hello@repodcast.io"
# CONTACT_EMAIL_SUPPORT="support@repodcast.io"
# CONTACT_EMAIL_PRIVACY="privacy@repodcast.io"
# CONTACT_EMAIL_SECURITY="security@repodcast.io"
# CONTACT_EMAIL_LEGAL="legal@repodcast.io"